{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aeonmi",
  "scopeName": "source.aeonmi",
  "fileTypes": ["ai", "aeon", "aeonmi"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#quantum_keywords" },
    { "include": "#builtins" },
    { "include": "#glyphs" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.aeonmi",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.aeonmi",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.aeonmi",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aeonmi",
          "match": "\\b(if|else|while|for|return|break|continue|match|in)\\b"
        },
        {
          "name": "keyword.declaration.aeonmi",
          "match": "\\b(let|const|fn|function|struct|enum|impl|trait|type|import|export|from|async|await|pub|mod)\\b"
        },
        {
          "name": "constant.language.aeonmi",
          "match": "\\b(true|false|null|nil)\\b"
        }
      ]
    },
    "quantum_keywords": {
      "patterns": [
        {
          "name": "keyword.other.quantum.aeonmi",
          "match": "\\b(qubit|superpose|entangle|measure|apply_gate|circuit|quantum|state|qft|grover|shor|teleport)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.aeonmi",
          "match": "\\b(print|log|len|push|pop|slice|concat|assert|panic|sqrt|abs|floor|ceil|round|min|max|format)\\b"
        }
      ]
    },
    "glyphs": {
      "patterns": [
        {
          "name": "keyword.operator.glyph.array.aeonmi",
          "match": "⧉"
        },
        {
          "name": "keyword.operator.glyph.slice.aeonmi",
          "match": "[⟨⟩]"
        },
        {
          "name": "keyword.operator.glyph.spread.aeonmi",
          "match": "…"
        },
        {
          "name": "keyword.operator.glyph.tensor.aeonmi",
          "match": "⊗"
        },
        {
          "name": "keyword.operator.glyph.bind.aeonmi",
          "match": "↦"
        },
        {
          "name": "keyword.operator.glyph.separator.aeonmi",
          "match": "‥"
        },
        {
          "name": "variable.other.binding.aeonmi",
          "match": "←"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.aeonmi",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.aeonmi",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.aeonmi",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.aeonmi",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.aeonmi",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.aeonmi",
          "match": "="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.aeonmi",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "variable.other.aeonmi",
          "match": "\\b[a-zA-Z_α-ωΑ-Ω][a-zA-Z0-9_α-ωΑ-Ω]*\\b"
        }
      ]
    }
  }
}
