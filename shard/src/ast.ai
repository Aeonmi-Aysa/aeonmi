// SHARD AST — pure Aeonmi (max 15 functions)

function ast_stmt(t, a, b, c, d) {
    if t == "Let"      { return { type: "Let",      name: a, value: b }; }
    if t == "Const"    { return { type: "Const",    name: a, value: b }; }
    if t == "Assign"   { return { type: "Assign",   target: a, value: b }; }
    if t == "Return"   { return { type: "Return",   value: a }; }
    if t == "ExprStmt" { return { type: "ExprStmt", expr: a }; }
    if t == "If"       { return { type: "If",       cond: a, then_body: b, else_body: c }; }
    if t == "While"    { return { type: "While",    cond: a, body: b }; }
    if t == "For"      { return { type: "For",      var_name: a, iter: b, body: c }; }
    if t == "Function" { return { type: "Function", name: a, params: b, body: c }; }
    if t == "Break"    { return { type: "Break" }; }
    if t == "Continue" { return { type: "Continue" }; }
    return { type: t };
}

function ast_literal(t, v) {
    if t == "Number" { return { type: "Number", value: v }; }
    if t == "String" { return { type: "String", value: v }; }
    if t == "Bool"   { return { type: "Bool",   value: v }; }
    if t == "Null"   { return { type: "Null" }; }
    return { type: t, value: v };
}

function ast_ident(name) { return { type: "Ident", name: name }; }

function ast_binop(op, left, right) {
    return { type: "BinOp", op: op, left: left, right: right };
}

function ast_unop(op, operand) { return { type: "UnOp", op: op, operand: operand }; }

function ast_call(callee, args) { return { type: "Call", callee: callee, args: args }; }

function ast_method(obj, meth, args) {
    return { type: "MethodCall", object: obj, method: meth, args: args };
}

function ast_index(obj, idx) { return { type: "Index", object: obj, index: idx }; }

function ast_field(obj, fname) { return { type: "Field", object: obj, field: fname }; }

function ast_array(elements) { return { type: "Array", elements: elements }; }

function ast_object(keys, vals) { return { type: "Object", keys: keys, values: vals }; }

function ast_program(body) { return { type: "Program", body: body }; }

function ast_type(node) { if node == null { return "null"; } return node.type; }

function ast_dump(node) {
    if node == null { return "null"; }
    let t = node.type;
    if t == "Number" { return "Number(" + toString(node.value) + ")"; }
    if t == "String" { return "String(" + node.value + ")"; }
    if t == "Bool"   { return "Bool(" + toString(node.value) + ")"; }
    if t == "Ident"  { return "Ident(" + node.name + ")"; }
    if t == "BinOp"  { return "BinOp(" + node.op + ")"; }
    if t == "Call"   { return "Call(" + node.callee + "/" + toString(node.len(args)) + ")"; }
    if t == "Let"    { return "Let(" + node.name + ")"; }
    if t == "Function" { return "Fn(" + node.name + "/" + toString(node.len(params)) + ")"; }
    return t;
}

let n = ast_stmt("Let", "x", ast_literal("Number", 42), null, null);
log("ast.ai loaded — " + ast_dump(n));
