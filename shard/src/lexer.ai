// SHARD Lexer — pure Aeonmi recursive lexer
// Tokenizes .ai source code into an array of token objects

const LEX_KW_FUNCTION  = "Function";
const LEX_KW_LET       = "Let";
const LEX_KW_CONST     = "Const";
const LEX_KW_IF        = "If";
const LEX_KW_ELSE      = "Else";
const LEX_KW_FOR       = "For";
const LEX_KW_IN        = "In";
const LEX_KW_WHILE     = "While";
const LEX_KW_RETURN    = "Return";
const LEX_KW_BREAK     = "Break";
const LEX_KW_CONTINUE  = "Continue";
const LEX_KW_TRUE      = "True";
const LEX_KW_FALSE     = "False";
const LEX_KW_NULL      = "Null";
const LEX_IDENT        = "Identifier";
const LEX_NUMBER       = "Number";
const LEX_STRING       = "String";
const LEX_PLUS         = "Plus";
const LEX_MINUS        = "Minus";
const LEX_STAR         = "Star";
const LEX_SLASH        = "Slash";
const LEX_PERCENT      = "Percent";
const LEX_STAR_STAR    = "StarStar";
const LEX_ASSIGN       = "Assign";
const LEX_PLUS_EQ      = "PlusEq";
const LEX_MINUS_EQ     = "MinusEq";
const LEX_EQ           = "Eq";
const LEX_NEQ          = "Neq";
const LEX_LT           = "Lt";
const LEX_LTE          = "Lte";
const LEX_GT           = "Gt";
const LEX_GTE          = "Gte";
const LEX_AND          = "And";
const LEX_OR           = "Or";
const LEX_NOT          = "Not";
const LEX_LPAREN       = "LParen";
const LEX_RPAREN       = "RParen";
const LEX_LBRACKET     = "LBracket";
const LEX_RBRACKET     = "RBracket";
const LEX_LBRACE       = "LBrace";
const LEX_RBRACE       = "RBrace";
const LEX_COMMA        = "Comma";
const LEX_SEMICOLON    = "Semicolon";
const LEX_COLON        = "Colon";
const LEX_DOT          = "Dot";
const LEX_EOF          = "EOF";
const LEX_UNKNOWN      = "Unknown";

function lex_is_digit(ch) {
    let code = char_code(ch);
    return code >= char_code("0") && code <= char_code("9");
}

function lex_is_alpha(ch) {
    let code = char_code(ch);
    let lo = code >= char_code("a") && code <= char_code("z");
    let hi = code >= char_code("A") && code <= char_code("Z");
    return lo || hi || ch == "_";
}

function lex_is_alnum(ch) {
    return lex_is_alpha(ch) || lex_is_digit(ch);
}

function lex_is_whitespace(ch) {
    return ch == " " || ch == "\t" || ch == "\n" || ch == "\r";
}

function lex_keyword(word) {
    if word == "function"  { return LEX_KW_FUNCTION; }
    if word == "let"       { return LEX_KW_LET; }
    if word == "const"     { return LEX_KW_CONST; }
    if word == "if"        { return LEX_KW_IF; }
    if word == "else"      { return LEX_KW_ELSE; }
    if word == "for"       { return LEX_KW_FOR; }
    if word == "in"        { return LEX_KW_IN; }
    if word == "while"     { return LEX_KW_WHILE; }
    if word == "return"    { return LEX_KW_RETURN; }
    if word == "break"     { return LEX_KW_BREAK; }
    if word == "continue"  { return LEX_KW_CONTINUE; }
    if word == "true"      { return LEX_KW_TRUE; }
    if word == "false"     { return LEX_KW_FALSE; }
    if word == "null"      { return LEX_KW_NULL; }
    return LEX_IDENT;
}

function lex_make(kind, value, line, col) {
    return { kind: kind, value: value, line: line, col: col };
}

function tokenize(source) {
    let tokens = [];
    let chars = source.split("");
    let pos = 0;
    let line = 1;
    let col = 1;
    let n = len(chars);

    while pos < n {
        let ch = chars[pos];

        // Skip whitespace
        if lex_is_whitespace(ch) {
            if ch == "\n" { line = line + 1; col = 1; }
            else { col = col + 1; }
            pos = pos + 1;
            continue;
        }

        // Single-line comment
        if ch == "/" && pos + 1 < n && chars[pos + 1] == "/" {
            while pos < n && chars[pos] != "\n" { pos = pos + 1; }
            continue;
        }

        // String literal
        if ch == "\"" {
            let start_col = col;
            let str_val = "";
            pos = pos + 1;
            col = col + 1;
            while pos < n && chars[pos] != "\"" {
                if chars[pos] == "\\" && pos + 1 < n {
                    pos = pos + 1;
                    col = col + 1;
                    let esc = chars[pos];
                    if esc == "n"  { str_val = str_val + "\n"; }
                    else if esc == "t" { str_val = str_val + "\t"; }
                    else { str_val = str_val + esc; }
                } else {
                    str_val = str_val + chars[pos];
                }
                pos = pos + 1;
                col = col + 1;
            }
            pos = pos + 1;
            col = col + 1;
            tokens.push(lex_make(LEX_STRING, str_val, line, start_col));
            continue;
        }

        // Number literal
        if lex_is_digit(ch) {
            let start_col = col;
            let num_val = "";
            let is_float = false;
            while pos < n && (lex_is_digit(chars[pos]) || chars[pos] == ".") {
                if chars[pos] == "." { is_float = true; }
                num_val = num_val + chars[pos];
                pos = pos + 1;
                col = col + 1;
            }
            tokens.push(lex_make(LEX_NUMBER, num_val, line, start_col));
            continue;
        }

        // Identifier or keyword
        if lex_is_alpha(ch) {
            let start_col = col;
            let word = "";
            while pos < n && lex_is_alnum(chars[pos]) {
                word = word + chars[pos];
                pos = pos + 1;
                col = col + 1;
            }
            let kind = lex_keyword(word);
            tokens.push(lex_make(kind, word, line, start_col));
            continue;
        }

        // Two-char operators
        if ch == "=" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_EQ, "==", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "!" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_NEQ, "!=", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "<" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_LTE, "<=", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == ">" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_GTE, ">=", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "&" && pos + 1 < n && chars[pos + 1] == "&" {
            tokens.push(lex_make(LEX_AND, "&&", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "|" && pos + 1 < n && chars[pos + 1] == "|" {
            tokens.push(lex_make(LEX_OR, "||", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "*" && pos + 1 < n && chars[pos + 1] == "*" {
            tokens.push(lex_make(LEX_STAR_STAR, "**", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "+" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_PLUS_EQ, "+=", line, col));
            pos = pos + 2; col = col + 2; continue;
        }
        if ch == "-" && pos + 1 < n && chars[pos + 1] == "=" {
            tokens.push(lex_make(LEX_MINUS_EQ, "-=", line, col));
            pos = pos + 2; col = col + 2; continue;
        }

        // Single-char tokens
        if ch == "+" { tokens.push(lex_make(LEX_PLUS,      "+", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "-" { tokens.push(lex_make(LEX_MINUS,     "-", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "*" { tokens.push(lex_make(LEX_STAR,      "*", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "/" { tokens.push(lex_make(LEX_SLASH,     "/", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "%" { tokens.push(lex_make(LEX_PERCENT,   "%", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "=" { tokens.push(lex_make(LEX_ASSIGN,    "=", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "<" { tokens.push(lex_make(LEX_LT,        "<", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == ">" { tokens.push(lex_make(LEX_GT,        ">", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "!" { tokens.push(lex_make(LEX_NOT,       "!", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "(" { tokens.push(lex_make(LEX_LPAREN,    "(", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == ")" { tokens.push(lex_make(LEX_RPAREN,    ")", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "[" { tokens.push(lex_make(LEX_LBRACKET,  "[", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "]" { tokens.push(lex_make(LEX_RBRACKET,  "]", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "{" { tokens.push(lex_make(LEX_LBRACE,    "{", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "}" { tokens.push(lex_make(LEX_RBRACE,    "}", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "," { tokens.push(lex_make(LEX_COMMA,     ",", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == ";" { tokens.push(lex_make(LEX_SEMICOLON, ";", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == ":" { tokens.push(lex_make(LEX_COLON,     ":", line, col)); pos=pos+1; col=col+1; continue; }
        if ch == "." { tokens.push(lex_make(LEX_DOT,       ".", line, col)); pos=pos+1; col=col+1; continue; }

        tokens.push(lex_make(LEX_UNKNOWN, ch, line, col));
        pos = pos + 1;
        col = col + 1;
    }

    tokens.push(lex_make(LEX_EOF, "", line, col));
    return tokens;
}

function tokenize_file(path) {
    let src = read_file(path);
    return tokenize(src);
}

function tokens_summary(tokens) {
    let counts = {};
    let i = 0;
    while i < len(tokens) {
        let k = tokens[i].kind;
        if object_has(counts, k) {
            counts[k] = counts[k] + 1;
        } else {
            counts[k] = 1;
        }
        i = i + 1;
    }
    return counts;
}

log("lexer.ai loaded — tokenize() ready");
