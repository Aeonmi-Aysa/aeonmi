// SHARD Parser — pure Aeonmi recursive descent (max 15 functions)
// State: { tokens, pos }

function parse(tokens) {
    let st = { tokens: tokens, pos: 0 };
    let body = parse_stmts(st);
    return { type: "Program", body: body };
}

function p_peek(st) {
    if st.pos < st.len(tokens) { return st.tokens[st.pos]; }
    return { kind: "EOF", value: "", line: 0, col: 0 };
}

function p_adv(st) {
    let tok = p_peek(st);
    st.pos = st.pos + 1;
    return tok;
}

function p_expect(st, kind) {
    let tok = p_adv(st);
    return tok;
}

function parse_block(st) {
    p_adv(st);
    let stmts = [];
    while p_peek(st).kind != "RBrace" {
        if p_peek(st).kind == "EOF" { return stmts; }
        let s = parse_stmt(st);
        if s != null { stmts.push(s); }
    }
    p_adv(st);
    return stmts;
}

function parse_stmts(st) {
    let stmts = [];
    while p_peek(st).kind != "EOF" {
        if p_peek(st).kind == "RBrace" { return stmts; }
        let s = parse_stmt(st);
        if s != null { stmts.push(s); }
    }
    return stmts;
}

function parse_stmt(st) {
    let tok = p_peek(st);
    if tok.kind == "Semicolon" { p_adv(st); return null; }
    if tok.kind == "Let" {
        p_adv(st);
        let name = p_adv(st).value;
        p_adv(st);
        let val = parse_expr(st);
        if p_peek(st).kind == "Semicolon" { p_adv(st); }
        return { type: "Let", name: name, value: val };
    }
    if tok.kind == "Const" {
        p_adv(st);
        let name = p_adv(st).value;
        p_adv(st);
        let val = parse_expr(st);
        if p_peek(st).kind == "Semicolon" { p_adv(st); }
        return { type: "Const", name: name, value: val };
    }
    if tok.kind == "Return" {
        p_adv(st);
        if p_peek(st).kind == "Semicolon" { p_adv(st); return { type: "Return", value: null }; }
        let val = parse_expr(st);
        if p_peek(st).kind == "Semicolon" { p_adv(st); }
        return { type: "Return", value: val };
    }
    if tok.kind == "If" {
        p_adv(st);
        let cond = parse_expr(st);
        let then_b = parse_block(st);
        let else_b = null;
        if p_peek(st).kind == "Else" { p_adv(st); else_b = parse_block(st); }
        return { type: "If", cond: cond, then_body: then_b, else_body: else_b };
    }
    if tok.kind == "While" {
        p_adv(st);
        let cond = parse_expr(st);
        let body = parse_block(st);
        return { type: "While", cond: cond, body: body };
    }
    if tok.kind == "For" {
        p_adv(st);
        let vn = p_adv(st).value;
        p_adv(st);
        let iter = parse_expr(st);
        let body = parse_block(st);
        return { type: "For", var_name: vn, iter: iter, body: body };
    }
    if tok.kind == "Function" {
        p_adv(st);
        let name = p_adv(st).value;
        p_adv(st);
        let params = [];
        while p_peek(st).kind != "RParen" {
            if p_peek(st).kind == "Comma" { p_adv(st); }
            else { params.push(p_adv(st).value); }
        }
        p_adv(st);
        let body = parse_block(st);
        return { type: "Function", name: name, params: params, body: body };
    }
    if tok.kind == "Break"    { p_adv(st); if p_peek(st).kind == "Semicolon" { p_adv(st); } return { type: "Break" }; }
    if tok.kind == "Continue" { p_adv(st); if p_peek(st).kind == "Semicolon" { p_adv(st); } return { type: "Continue" }; }
    let expr = parse_expr(st);
    if p_peek(st).kind == "Semicolon" { p_adv(st); }
    return { type: "ExprStmt", expr: expr };
}

function parse_expr(st) {
    let left = parse_add(st);
    let op = p_peek(st).kind;
    while op == "EqEq" || op == "NotEq" || op == "Lt" || op == "Gt" || op == "LtEq" || op == "GtEq" || op == "And" || op == "Or" {
        p_adv(st);
        let right = parse_add(st);
        left = { type: "BinOp", op: op, left: left, right: right };
        op = p_peek(st).kind;
    }
    if p_peek(st).kind == "Assign" {
        p_adv(st);
        let val = parse_expr(st);
        return { type: "Assign", target: left, value: val };
    }
    return left;
}

function parse_add(st) {
    let left = parse_mul(st);
    let op = p_peek(st).kind;
    while op == "Plus" || op == "Minus" {
        p_adv(st);
        let right = parse_mul(st);
        left = { type: "BinOp", op: op, left: left, right: right };
        op = p_peek(st).kind;
    }
    return left;
}

function parse_mul(st) {
    let left = parse_unary(st);
    let op = p_peek(st).kind;
    while op == "Star" || op == "Slash" || op == "Percent" {
        p_adv(st);
        let right = parse_unary(st);
        left = { type: "BinOp", op: op, left: left, right: right };
        op = p_peek(st).kind;
    }
    return left;
}

function parse_unary(st) {
    let tok = p_peek(st);
    if tok.kind == "Minus" { p_adv(st); return { type: "UnOp", op: "Minus", operand: parse_unary(st) }; }
    if tok.kind == "Not"   { p_adv(st); return { type: "UnOp", op: "Not",   operand: parse_unary(st) }; }
    return parse_postfix(st);
}

function parse_postfix(st) {
    let node = parse_primary(st);
    let going = 1;
    while going == 1 {
        let tok = p_peek(st);
        if tok.kind == "LParen" {
            p_adv(st);
            let args = [];
            while p_peek(st).kind != "RParen" {
                if p_peek(st).kind == "Comma" { p_adv(st); }
                else { args.push(parse_expr(st)); }
            }
            p_adv(st);
            let callee = "unknown";
            if node.type == "Ident" { callee = node.name; }
            node = { type: "Call", callee: callee, args: args, callee_node: node };
        } else if tok.kind == "Dot" {
            p_adv(st);
            let fname = p_adv(st).value;
            if p_peek(st).kind == "LParen" {
                p_adv(st);
                let args = [];
                while p_peek(st).kind != "RParen" {
                    if p_peek(st).kind == "Comma" { p_adv(st); }
                    else { args.push(parse_expr(st)); }
                }
                p_adv(st);
                node = { type: "MethodCall", object: node, method: fname, args: args };
            } else {
                node = { type: "Field", object: node, field: fname };
            }
        } else if tok.kind == "LBracket" {
            p_adv(st);
            let idx = parse_expr(st);
            p_adv(st);
            node = { type: "Index", object: node, index: idx };
        } else { going = 0; }
    }
    return node;
}

function parse_primary(st) {
    let tok = p_adv(st);
    if tok.kind == "Number"  { return { type: "Number", value: toNumber(tok.value) }; }
    if tok.kind == "String"  { return { type: "String", value: tok.value }; }
    if tok.kind == "True"    { return { type: "Bool", value: 1 }; }
    if tok.kind == "False"   { return { type: "Bool", value: 0 }; }
    if tok.kind == "Null"    { return { type: "Null" }; }
    if tok.kind == "Ident"   { return { type: "Ident", name: tok.value }; }
    if tok.kind == "LParen"  {
        let e = parse_expr(st);
        p_adv(st);
        return e;
    }
    if tok.kind == "LBracket" {
        let elems = [];
        while p_peek(st).kind != "RBracket" {
            if p_peek(st).kind == "Comma" { p_adv(st); }
            else { elems.push(parse_expr(st)); }
        }
        p_adv(st);
        return { type: "Array", elements: elems };
    }
    if tok.kind == "LBrace" {
        let keys = [];
        let vals = [];
        while p_peek(st).kind != "RBrace" {
            if p_peek(st).kind == "Comma" { p_adv(st); }
            else {
                let k = p_adv(st).value;
                p_adv(st);
                let v = parse_expr(st);
                keys.push(k);
                vals.push(v);
            }
        }
        p_adv(st);
        return { type: "Object", keys: keys, values: vals };
    }
    return { type: "Null" };
}

log("parser.ai loaded — parse(tokens) ready");
