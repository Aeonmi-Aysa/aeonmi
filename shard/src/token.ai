// SHARD Token Definitions — pure Aeonmi syntax

const TK_FUNCTION   = "Function";
const TK_LET        = "Let";
const TK_CONST      = "Const";
const TK_IF         = "If";
const TK_ELSE       = "Else";
const TK_FOR        = "For";
const TK_IN         = "In";
const TK_WHILE      = "While";
const TK_RETURN     = "Return";
const TK_BREAK      = "Break";
const TK_CONTINUE   = "Continue";
const TK_TRUE       = "True";
const TK_FALSE      = "False";
const TK_NULL       = "Null";
const TK_QUBIT      = "Qubit";
const TK_QUANTUM    = "Quantum";
const TK_MEASURE    = "Measure";
const TK_SUPERPOSE  = "Superpose";
const TK_ENTANGLE   = "Entangle";

const TK_IDENT      = "Identifier";
const TK_NUMBER     = "Number";
const TK_STRING     = "String";

const TK_PLUS       = "Plus";
const TK_MINUS      = "Minus";
const TK_STAR       = "Star";
const TK_SLASH      = "Slash";
const TK_PERCENT    = "Percent";
const TK_STAR_STAR  = "StarStar";
const TK_ASSIGN     = "Assign";
const TK_PLUS_EQ    = "PlusEq";
const TK_MINUS_EQ   = "MinusEq";
const TK_EQ         = "Eq";
const TK_NEQ        = "Neq";
const TK_LT         = "Lt";
const TK_LTE        = "Lte";
const TK_GT         = "Gt";
const TK_GTE        = "Gte";
const TK_AND        = "And";
const TK_OR         = "Or";
const TK_NOT        = "Not";
const TK_LPAREN     = "LParen";
const TK_RPAREN     = "RParen";
const TK_LBRACKET   = "LBracket";
const TK_RBRACKET   = "RBracket";
const TK_LBRACE     = "LBrace";
const TK_RBRACE     = "RBrace";
const TK_COMMA      = "Comma";
const TK_SEMICOLON  = "Semicolon";
const TK_COLON      = "Colon";
const TK_DOT        = "Dot";
const TK_ARROW      = "Arrow";
const TK_EOF        = "EOF";
const TK_UNKNOWN    = "Unknown";

function make_token(kind, value, line, col) {
    return { kind: kind, value: value, line: line, col: col };
}

function token_is_keyword(tok) {
    let kw = [TK_FUNCTION, TK_LET, TK_CONST, TK_IF, TK_ELSE, TK_FOR, TK_IN,
              TK_WHILE, TK_RETURN, TK_BREAK, TK_CONTINUE, TK_TRUE, TK_FALSE,
              TK_NULL, TK_QUBIT, TK_QUANTUM, TK_MEASURE, TK_SUPERPOSE, TK_ENTANGLE];
    let i = 0;
    while i < len(kw) {
        if kw[i] == tok.kind { return true; }
        i = i + 1;
    }
    return false;
}

function token_is_literal(tok) {
    if tok.kind == TK_NUMBER { return true; }
    if tok.kind == TK_STRING { return true; }
    if tok.kind == TK_TRUE   { return true; }
    if tok.kind == TK_FALSE  { return true; }
    if tok.kind == TK_NULL   { return true; }
    return false;
}

function token_is_op(tok) {
    if tok.kind == TK_PLUS  { return true; }
    if tok.kind == TK_MINUS { return true; }
    if tok.kind == TK_STAR  { return true; }
    if tok.kind == TK_SLASH { return true; }
    if tok.kind == TK_EQ    { return true; }
    if tok.kind == TK_NEQ   { return true; }
    if tok.kind == TK_LT    { return true; }
    if tok.kind == TK_GT    { return true; }
    if tok.kind == TK_AND   { return true; }
    if tok.kind == TK_OR    { return true; }
    return false;
}

function token_precedence(tok) {
    if tok.kind == TK_OR      { return 1; }
    if tok.kind == TK_AND     { return 2; }
    if tok.kind == TK_EQ      { return 3; }
    if tok.kind == TK_NEQ     { return 3; }
    if tok.kind == TK_LT      { return 4; }
    if tok.kind == TK_LTE     { return 4; }
    if tok.kind == TK_GT      { return 4; }
    if tok.kind == TK_GTE     { return 4; }
    if tok.kind == TK_PLUS    { return 5; }
    if tok.kind == TK_MINUS   { return 5; }
    if tok.kind == TK_STAR    { return 6; }
    if tok.kind == TK_SLASH   { return 6; }
    if tok.kind == TK_PERCENT { return 6; }
    if tok.kind == TK_STAR_STAR { return 7; }
    return 0;
}

function token_to_string(tok) {
    return "Token(" + tok.kind + ", '" + tok.value + "', " + toString(tok.line) + ":" + toString(tok.col) + ")";
}

function keyword_kind(word) {
    if word == "function"  { return TK_FUNCTION; }
    if word == "let"       { return TK_LET; }
    if word == "const"     { return TK_CONST; }
    if word == "if"        { return TK_IF; }
    if word == "else"      { return TK_ELSE; }
    if word == "for"       { return TK_FOR; }
    if word == "in"        { return TK_IN; }
    if word == "while"     { return TK_WHILE; }
    if word == "return"    { return TK_RETURN; }
    if word == "break"     { return TK_BREAK; }
    if word == "continue"  { return TK_CONTINUE; }
    if word == "true"      { return TK_TRUE; }
    if word == "false"     { return TK_FALSE; }
    if word == "null"      { return TK_NULL; }
    if word == "qubit"     { return TK_QUBIT; }
    if word == "quantum"   { return TK_QUANTUM; }
    if word == "measure"   { return TK_MEASURE; }
    if word == "superpose" { return TK_SUPERPOSE; }
    if word == "entangle"  { return TK_ENTANGLE; }
    return TK_IDENT;
}

log("token.ai loaded — " + toString(50) + " token types defined");
