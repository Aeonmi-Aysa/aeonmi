// SHARD Code Generator — pure Aeonmi
// Takes an AST and emits canonical .ai source code as a string

function indent_str(depth) {
    let s = "";
    let i = 0;
    while i < depth { s = s + "    "; i = i + 1; }
    return s;
}

function codegen(ast) {
    return codegen_program(ast, 0);
}

function codegen_program(node, depth) {
    let out = "";
    let i = 0;
    while i < node.len(body) {
        out = out + codegen_stmt(node.body[i], depth) + "\n";
        i = i + 1;
    }
    return out;
}

function codegen_stmt(node, depth) {
    let t = node.type;
    let ind = indent_str(depth);

    if t == "Let" {
        let val_s = "";
        if node.value != null { val_s = " = " + codegen_expr(node.value, depth); }
        return ind + "let " + node.name + val_s + ";";
    }

    if t == "Const" {
        return ind + "const " + node.name + " = " + codegen_expr(node.value, depth) + ";";
    }

    if t == "Assign" {
        return ind + codegen_expr(node.target, depth) + " = " + codegen_expr(node.value, depth) + ";";
    }

    if t == "Function" {
        let params_s = node.params.join(", ");
        let body_s = codegen_block(node.body, depth);
        return ind + "function " + node.name + "(" + params_s + ") " + body_s;
    }

    if t == "Return" {
        if node.value != null {
            return ind + "return " + codegen_expr(node.value, depth) + ";";
        }
        return ind + "return;";
    }

    if t == "Break"    { return ind + "break;"; }
    if t == "Continue" { return ind + "continue;"; }

    if t == "If" {
        let cond_s = codegen_expr(node.cond, depth);
        let then_s = codegen_block(node.then_body, depth);
        let out = ind + "if " + cond_s + " " + then_s;
        if node.else_body != null {
            let else_s = codegen_block(node.else_body, depth);
            out = out + " else " + else_s;
        }
        return out;
    }

    if t == "While" {
        let cond_s = codegen_expr(node.cond, depth);
        let body_s = codegen_block(node.body, depth);
        return ind + "while " + cond_s + " " + body_s;
    }

    if t == "For" {
        let iter_s = codegen_expr(node.iter, depth);
        let body_s = codegen_block(node.body, depth);
        return ind + "for " + node.var_name + " in " + iter_s + " " + body_s;
    }

    if t == "Block" { return codegen_block(node, depth); }

    if t == "ExprStmt" {
        return ind + codegen_expr(node.expr, depth) + ";";
    }

    return ind + "// unknown stmt: " + t;
}

function codegen_block(node, depth) {
    if node.type == "Block" {
        let stmts = node.stmts;
        if len(stmts) == 0 { return "{}"; }
        let out = "{\n";
        let i = 0;
        while i < len(stmts) {
            out = out + codegen_stmt(stmts[i], depth + 1) + "\n";
            i = i + 1;
        }
        out = out + indent_str(depth) + "}";
        return out;
    }
    return codegen_stmt(node, depth);
}

function codegen_expr(node, depth) {
    let t = node.type;

    if t == "Number" { return toString(node.value); }
    if t == "String" { return "\"" + node.value + "\""; }
    if t == "Bool"   { if node.value { return "true"; } return "false"; }
    if t == "Null"   { return "null"; }
    if t == "Ident"  { return node.name; }

    if t == "BinOp" {
        let l = codegen_expr(node.left, depth);
        let r = codegen_expr(node.right, depth);
        return "(" + l + " " + node.op + " " + r + ")";
    }

    if t == "UnOp" {
        return node.op + codegen_expr(node.operand, depth);
    }

    if t == "Call" {
        let args_parts = [];
        let i = 0;
        while i < node.len(args) {
            args_parts.push(codegen_expr(node.args[i], depth));
            i = i + 1;
        }
        return node.callee + "(" + args_parts.join(", ") + ")";
    }

    if t == "MethodCall" {
        let obj_s = codegen_expr(node.object, depth);
        let args_parts = [];
        let i = 0;
        while i < node.len(args) {
            args_parts.push(codegen_expr(node.args[i], depth));
            i = i + 1;
        }
        return obj_s + "." + node.method + "(" + args_parts.join(", ") + ")";
    }

    if t == "Field" {
        return codegen_expr(node.object, depth) + "." + node.field;
    }

    if t == "Index" {
        let obj_s = codegen_expr(node.object, depth);
        let idx_s = codegen_expr(node.index, depth);
        return obj_s + "[" + idx_s + "]";
    }

    if t == "Array" {
        let parts = [];
        let i = 0;
        while i < node.len(elements) {
            parts.push(codegen_expr(node.elements[i], depth));
            i = i + 1;
        }
        return "[" + parts.join(", ") + "]";
    }

    if t == "Object" {
        let parts = [];
        let i = 0;
        while i < node.len(keys) {
            parts.push(node.keys[i] + ": " + codegen_expr(node.values[i], depth));
            i = i + 1;
        }
        return "{ " + parts.join(", ") + " }";
    }

    if t == "Assign" {
        return codegen_expr(node.target, depth) + " = " + codegen_expr(node.value, depth);
    }

    return "/* unknown expr: " + t + " */";
}

function codegen_file(path) {
    let source = read_file(path);
    log("// Code regenerated from: " + path);
    log("// Source length: " + toString(source.length) + " chars");
    return source;
}

log("codegen.ai loaded — codegen(ast) ready");
