let dj = deutsch_jozsa("balanced");
log("Summary: " + json_stringify(dj));

log("");
log(">>> Quantum Teleportation <<<");
let tp = quantum_teleport("|psi>");

log("");
log(">>> Phase Estimation <<<");
let pe = quantum_phase_estimation(5);

log("");
log(">>> VQE <<<");
let e = vqe_run(3, 10);

log("");
log("=== All quantum algorithms complete ===");
