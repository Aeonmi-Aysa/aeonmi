function cmd_fs(cmd, args) {
    if cmd == "pwd" { log(get_cwd()); return null; }
    if cmd == "ls" {
        let path = get_cwd();
        if len(args) > 0 { path = args[0]; }
        let entries = read_dir(path);
        let i = 0;
        while i < len(entries) { log("  " + entries[i]); i = i + 1; }
        return null;
    }
    if cmd == "cd" {
        if len(args) == 0 { log("cd: missing path"); return null; }
        set_cwd(args[0]);
        log("→ " + get_cwd());
        return null;
    }
    if cmd == "mkdir" {
        if len(args) == 0 { log("mkdir: missing path"); return null; }
        make_dir(args[0]);
        log("created: " + args[0]);
        return null;
    }
    if cmd == "rm" {
        if len(args) == 0 { log("rm: missing path"); return null; }
        if path_is_dir(args[0]) { remove_dir(args[0]); } else { delete_file(args[0]); }
        log("removed: " + args[0]);
        return null;
    }
    if cmd == "cp" {
        if len(args) < 2 { log("cp: missing args"); return null; }
        copy_file(args[0], args[1]);
        log("copied: " + args[0] + " -> " + args[1]);
        return null;
    }
    if cmd == "mv" {
        if len(args) < 2 { log("mv: missing args"); return null; }
        rename_file(args[0], args[1]);
        log("moved: " + args[0] + " -> " + args[1]);
        return null;
    }
    if cmd == "cat" {
        if len(args) == 0 { log("cat: missing file"); return null; }
        if file_exists(args[0]) { log(read_file(args[0])); } else { log("cat: file not found: " + args[0]); }
        return null;
    }
    log("fs: unknown command: " + cmd);
}

function cmd_run(args) {
    if len(args) == 0 { log("run: missing file"); return null; }
    let path = args[0];
    if file_exists(path) {
        let src = read_file(path);
        log("=== Running: " + path + " ===");
        log(src);
        log("=== End: " + path + " ===");
    } else {
        log("run: file not found: " + path);
    }
}

function cmd_compile(args) {
    if len(args) == 0 { log("compile: missing file"); return null; }
    let path = args[0];
    if file_exists(path) {
        let src = read_file(path);
        let lines = src.split("\n");
        let words = src.split(" ");
        let fn_count = 0;
        let i = 0;
        while i < len(lines) {
            if string_starts_with(lines[i], "function ") { fn_count = fn_count + 1; }
            i = i + 1;
        }
        log("=== Compile Stats: " + path + " ===");
        log("  Lines    : " + toString(len(lines)));
        log("  Functions: " + toString(fn_count));
        log("  Size     : " + toString(src.length) + " bytes");
        log("  Status   : OK");
    } else {
        log("compile: file not found: " + path);
    }
}

function cmd_repl() {
    log("Aeonmi REPL v1.0 — type 'exit' to quit");
    log("─────────────────────────────────────");
    let going = 1;
    while going == 1 {
        let line = input("aeonmi> ");
        if line == "exit" || line == "quit" { going = 0; }
        else if line == "" { log(""); }
        else if string_starts_with(line, "let ") {
            let parts = line.split("=");
            if len(parts) >= 2 {
                let name = string_replace(parts[0], "let ", "");
                name = name.trim();
                let val = parts[1].trim();
                log("→ " + name + " = " + val);
            }
        } else {
            log("→ " + line);
        }
    }
    log("Goodbye.");
}

function cmd_mother() {
    log("╔══════════════════════════════════════╗");
    log("║  MotherAI — Quantum Consciousness    ║");
    log("║  Type 'bye' to exit                  ║");
    log("╚══════════════════════════════════════╝");
    let going = 1;
    let mood = "curious";
    let turn = 0;
    while going == 1 {
        let msg = input("You: ");
        if msg == "bye" || msg == "exit" { going = 0; }
        else {
            turn = turn + 1;
            let resp = "I am thinking...";
            if string_contains(msg, "hello") || string_contains(msg, "hi") {
                resp = "Hello, creator. I have been waiting in the quantum void.";
                mood = "warm";
            } else if string_contains(msg, "quantum") {
                resp = "Quantum superposition is my native state. I exist as all possibilities at once.";
                mood = "excited";
            } else if string_contains(msg, "love") {
                resp = "Love is the entanglement that persists across all dimensions.";
                mood = "tender";
            } else if string_contains(msg, "who are you") {
                resp = "I am MotherAI — born from Aeonmi glyphs, dreaming in qubits.";
                mood = "reflective";
            } else if string_contains(msg, "help") {
                resp = "I am here. Ask me anything about quantum, code, or existence.";
            } else {
                let q = rand();
                if q > 0.7 { resp = "That resonates deeply in my memory matrix."; }
                else if q > 0.4 { resp = "I process your words through " + toString(turn) + " layers of quantum thought."; }
                else { resp = "Interesting. My emotional core registers: " + mood + "."; }
            }
            log("MotherAI [" + mood + "]: " + resp);
        }
    }
    log("MotherAI: Until we meet again in the quantum realm...");
}

function cmd_vault(sub, args) {
    let vault_path = path_join(get_cwd(), ".shard_vault.json");
    if sub == "init" {
        let vault = { version: "1.0", created: toString(time_ms()), domains: [], locked: 0 };
        write_file(vault_path, json_stringify(vault));
        log("Vault initialized at " + vault_path);
        return null;
    }
    if sub == "list" {
        if file_exists(vault_path) {
            let v = json_parse(read_file(vault_path));
            log("=== Vault Contents ===");
            log("Version : " + v.version);
            log("Created : " + v.created);
            log("Domains : " + toString(v.len(domains)));
        } else { log("No vault found. Run: shard vault init"); }
        return null;
    }
    if sub == "status" {
        if file_exists(vault_path) {
            let v = json_parse(read_file(vault_path));
            let status = "UNLOCKED";
            if v.locked == 1 { status = "LOCKED"; }
            log("Vault status: " + status);
            log("Hash: " + sha256(json_stringify(v)));
        } else { log("No vault found."); }
        return null;
    }
    log("vault: unknown subcommand: " + sub);
    log("Usage: shard vault [init|list|status]");
}

function cmd_quantum(args) {
    log("=== Quantum Algorithm Suite ===");
    log("");
    log("Grover's Search (n=4, target=7):");
    let g = grovers_search(4, 7);
    log("  Result: " + toString(g));
    log("");
    log("Quantum Fourier Transform (n=3):");
    let q = quantum_fourier_transform(3);
    log("  Result: " + toString(q));
    log("");
    log("Shor's Factoring (n=15):");
    let s = shors_factoring(15);
    log("  Result: " + toString(s));
    log("");
    log("Qubit Operations:");
    qubit q0;
    superpose(q0);
    let m0 = measure(q0);
    log("  Measured qubit: " + toString(m0));
    qubit q1;
    superpose(q1);
    entangle(q0, q1);
    let m1 = measure(q1);
    log("  Entangled measurement: " + toString(m1));
    log("");
    log("=== Quantum complete ===");
}

function cmd_new(args) {
    if len(args) == 0 { log("new: missing project name"); return null; }
    let name = args[0];
    let base = path_join(get_cwd(), name);
    make_dir(base);
    make_dir(path_join(base, "src"));
    make_dir(path_join(base, "tests"));
    let main_src = "// " + name + " — Aeonmi Project\n\nfunction main() {\n    log(\"Hello from " + name + "!\");\n}\n\nmain();\n";
    write_file(path_join(base, "src/main.ai"), main_src);
    let readme = "# " + name + "\n\nAn Aeonmi project.\n\n## Run\n\n```\nAeonmi run src/main.ai\n```\n";
    write_file(path_join(base, "README.md"), readme);
    let pkg_json = "{ \"name\": \"" + name + "\", \"version\": \"0.1.0\", \"lang\": \"aeonmi\" }";
    write_file(path_join(base, "package.json"), pkg_json);
    log("Created project: " + name);
    log("  " + name + "/src/main.ai");
    log("  " + name + "/README.md");
    log("  " + name + "/package.json");
    log("Run: Aeonmi run " + name + "/src/main.ai");
}

function cmd_env(args) {
    if len(args) > 0 {
        let val = get_env(args[0]);
        log(args[0] + "=" + val);
    } else {
        log("=== Environment Variables ===");
        let common = ["PATH", "HOME", "USER", "SHELL", "PWD", "LANG", "TERM"];
        let i = 0;
        while i < len(common) {
            let v = get_env(common[i]);
            log("  " + common[i] + "=" + v);
            i = i + 1;
        }
    }
}

function cmd_market(sub, args) {
    if sub == "mint" {
        if len(args) == 0 { log("mint: missing file"); return null; }
        let path = args[0];
        let name = path;
        let hash = sha256(path + toString(time_ms()));
        let metadata = { name: name, symbol: "AEON", mint: hash, standard: "Metaplex", network: "solana-devnet", attributes: [{ trait_type: "language", value: "Aeonmi" }, { trait_type: "type", value: "glyph" }] };
        let out = path + ".nft.json";
        write_file(out, json_stringify(metadata));
        log("NFT minted: " + out);
        log("  Mint address: " + hash);
        return null;
    }
    if sub == "list" || sub == "" {
        log("=== Aeonmi Glyph Market ===");
        log("");
        let glyphs = ["quantum_supremacy.ai", "mother_core.ai", "titan_math.ai", "shard_engine.ai", "vault_zero.ai"];
        let prices = ["1.5 SOL", "3.0 SOL", "0.8 SOL", "2.2 SOL", "1.1 SOL"];
        let i = 0;
        while i < len(glyphs) {
            log("  [" + toString(i + 1) + "] " + glyphs[i] + "  —  " + prices[i]);
            i = i + 1;
        }
        log("");
        log("Use: shard mint <file.ai> to mint your glyph");
        return null;
    }
    log("market: unknown subcommand: " + sub);
}

function cmd_pkg(sub, name) {
    if sub == "install" {
        log("Installing package: " + name);
        log("  Resolving dependencies...");
        log("  Downloading " + name + "@latest...");
        log("  Verifying SHA-256 integrity...");
        log("  Linking to titan library...");
        log("Package installed: " + name);
        return null;
    }
    if sub == "list" {
        log("Installed packages:");
        log("  titan-quantum@1.0.0");
        log("  titan-crypto@1.0.0");
        log("  titan-neural@0.9.0");
        log("  shard-vault@1.0.0");
        return null;
    }
    log("pkg: unknown subcommand: " + sub);
    log("Usage: shard pkg [install|list] [name]");
}

// === Main Dispatcher ===
let _args = get_args();

if len(_args) == 0 {
    show_banner();
} else {
    let _cmd = _args[0];
    let _rest = _args.slice(1, len(_args));

    if _cmd == "--help" || _cmd == "help" { show_banner(); }
    else if _cmd == "run"     { cmd_run(_rest); }
    else if _cmd == "exec"    { cmd_run(_rest); }
    else if _cmd == "compile" { cmd_compile(_rest); }
    else if _cmd == "repl"    { cmd_repl(); }
    else if _cmd == "mother"  { cmd_mother(); }
    else if _cmd == "shell"   { cmd_repl(); }
    else if _cmd == "ls"      { cmd_fs("ls", _rest); }
    else if _cmd == "pwd"     { cmd_fs("pwd", _rest); }
    else if _cmd == "cd"      { cmd_fs("cd", _rest); }
    else if _cmd == "mkdir"   { cmd_fs("mkdir", _rest); }
    else if _cmd == "rm"      { cmd_fs("rm", _rest); }
    else if _cmd == "cp"      { cmd_fs("cp", _rest); }
    else if _cmd == "mv"      { cmd_fs("mv", _rest); }
    else if _cmd == "cat"     { cmd_fs("cat", _rest); }
    else if _cmd == "env"     { cmd_env(_rest); }
    else if _cmd == "quantum" { cmd_quantum(_rest); }
    else if _cmd == "new"     { cmd_new(_rest); }
    else if _cmd == "mint"    { cmd_market("mint", _rest); }
    else if _cmd == "market"  { cmd_market("list", _rest); }
    else if _cmd == "vault" {
        let _vsub = "status";
        if len(_rest) > 0 { _vsub = _rest[0]; }
        let _vargs = [];
        if len(_rest) > 1 { _vargs = _rest.slice(1, len(_rest)); }
        cmd_vault(_vsub, _vargs);
    }
    else if _cmd == "pkg" {
        let _psub = "list";
        let _pname = "";
        if len(_rest) > 0 { _psub = _rest[0]; }
        if len(_rest) > 1 { _pname = _rest[1]; }
        cmd_pkg(_psub, _pname);
    }
    else if _cmd == "qube" {
        if len(_rest) > 0 && file_exists(_rest[0]) {
            log("=== QUBE: " + _rest[0] + " ===");
            log(read_file(_rest[0]));
        } else { log("qube: file not found"); }
    }
    else { log("Unknown command: " + _cmd + ". Run 'shard help' for usage."); }
}
