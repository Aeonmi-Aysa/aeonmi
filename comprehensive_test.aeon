// Comprehensive AEONMI Quantum AST Test
// Testing all quantum constructs end-to-end

// 1. Test Quantum State Literals
let zero_state = |0⟩;
let one_state = |1⟩;
let plus_state = |+⟩;
let minus_state = |-⟩;
let bell_state = |00⟩;

// 2. Test Basic Variables and Assignment
let classical_value = 42;
let quantum_amplitude = 0.707;

// 3. Test Function Definition (will be processed by our QuantumFunction AST)
function test_classical_func(x, y) {
    return x + y;
}

// 4. Test Basic Control Flow (will trigger our ProbabilityBranch and QuantumLoop AST)
if classical_value > 0 {
    let positive = true;
}

// 5. Test Loop Structure (will be processed by our QuantumLoop AST)
for i in range(3) {
    let iteration = i;
}

// 6. Test Array Operations (will trigger QuantumIndexAccess AST)
let quantum_array = [|0⟩, |1⟩, |+⟩];
let first_element = quantum_array[0];

// 7. Test Binary Operations (will be processed by QuantumBinaryExpr AST)
let result1 = classical_value + 10;
let result2 = quantum_amplitude * 2;

// 8. Test Nested Expressions
let complex_expr = (classical_value + 5) * quantum_amplitude;

// 9. Test Multiple Statements in Blocks
{
    let local_var = 100;
    let calculation = local_var / 2;
}

// 10. Test Return Statements
function return_test() {
    return 123;
}

print("AEONMI Quantum AST Test Complete");