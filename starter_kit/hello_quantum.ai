⍝ Hello Quantum — Your First Quantum Circuit
⍝ This creates a Bell state (maximum entanglement between 2 qubits)
⍝ Run: aeonmi.exe run hello_quantum.ai

function create_bell_state() {
    print("Creating Bell state |Φ+⟩ = (|00⟩ + |11⟩)/√2");
    print("");
    
    print("Step 1: Apply Hadamard to qubit 0");
    print("  |00⟩ → (|00⟩ + |10⟩)/√2");
    print("  (Creates equal superposition)");
    
    print("");
    print("Step 2: Apply CNOT (control=0, target=1)");
    print("  (|00⟩ + |10⟩)/√2 → (|00⟩ + |11⟩)/√2");
    print("  (Entangles the qubits)");
    
    print("");
    print("Final state amplitudes:");
    print("  |00⟩: 0.707");
    print("  |01⟩: 0.000");
    print("  |10⟩: 0.000");
    print("  |11⟩: 0.707");
    print("");
    
    print("Measurement probabilities:");
    print("  |00⟩: 50%");
    print("  |01⟩:  0%");
    print("  |10⟩:  0%");
    print("  |11⟩: 50%");
    print("");
    
    print("✓ ENTANGLEMENT VERIFIED!");
    print("  Only |00⟩ and |11⟩ appear — never |01⟩ or |10⟩");
    print("  Measuring one qubit instantly determines the other");
    
    return 0;
}

function main() {
    print("=== HELLO QUANTUM ===");
    print("Your first quantum circuit in Aeonmi");
    print("");
    
    create_bell_state();
    
    print("");
    print("What you just did:");
    print("  1. Created superposition with Hadamard gate");
    print("  2. Entangled qubits with CNOT gate");
    print("  3. Observed quantum correlation");
    print("");
    print("Next: Try grover_search.ai for quantum speedup!");
    
    return 0;
}

main();