# 6. Circuit Optimization Example
print("=== Quantum Circuit Optimization ===")
𓀁 unoptimized_circuit = [
    "x 0",
    "x 0",      # Double X gate (cancels out)
    "h 0", 
    "h 0",      # Double H gate (cancels out)
    "y 1"
]
print("Unoptimized circuit:", unoptimized_circuit)

𓀁 optimized_circuit = [
    "y 1"       # Only the Y gate remains after optimization
]
print("Optimized circuit:", optimized_circuit)

𓀀 opt_job_id = submit_job("aeonmi_simulator", optimized_circuit, 500)
𓀀 opt_results = job_results(opt_job_id)
print("Optimized circuit results:", opt_results["counts"])
print("")

# 7. Algorithm Integration with Hardware
print("=== Running Quantum Algorithms on Hardware ===")

# Combine algorithm with hardware execution
𓀀 grover_result = grovers_search(4, 2)
print("Grover's algorithm result:", grover_result)

# Create circuit for Bernstein-Vazirani algorithm
𓀁 bv_circuit = [
    "h 0",
    "h 1", 
    "cx 0 2",   # Oracle for hidden string "01"
    "h 0",
    "h 1"
]
𓀀 bv_job_id = submit_job("aeonmi_simulator", bv_circuit, 1000)
𓀀 bv_results = job_results(bv_job_id)
print("Bernstein-Vazirani hardware execution:", bv_results["counts"])
print("")

