# AEONMI Real Hardware Integration Demo
# Showcasing quantum computing on real hardware and cloud providers

⟦ Hardware Integration Testing ⟧

print("=== AEONMI Quantum Hardware Integration ===")
print("")

# 1. List Available Quantum Devices
print("=== Available Quantum Devices ===")
𓀁 devices = list_devices()
print("Found", len(devices), "quantum devices:")

𓀂(device ∈ devices) ⟦
    print("  Device:", device["name"])
    print("    Provider:", device["provider"])
    print("    Qubits:", device["qubits"])
    print("    Available:", device["available"])
    print("    Queue Length:", device["queue_length"])
    print("")
⟧

# 2. Simple Bell State Circuit
print("=== Creating Bell State Circuit ===")
𓀁 bell_circuit = [
    "h 0",      # Hadamard on qubit 0
    "cx 0 1"    # CNOT from qubit 0 to 1
]
print("Circuit gates:", bell_circuit)
print("")

# 3. Submit Job to Local Simulator
print("=== Submitting to Local Simulator ===")
𓀀 sim_job_id = submit_job("aeonmi_simulator", bell_circuit, 1000)
print("Simulator job ID:", sim_job_id)

𓀀 sim_status = job_status(sim_job_id)
print("Job status:", sim_status)

⦅ (sim_status == "completed") ⦆ ⟦
    𓀀 sim_results = job_results(sim_job_id)
    print("Simulation results:")
    print("  Counts:", sim_results["counts"])
    print("  Probabilities:", sim_results["probabilities"])
    print("  Execution time:", sim_results["execution_time"], "seconds")
    print("  Total shots:", sim_results["shots"])
⟧ ⦆ ⟦
    print("Simulation job not yet completed")
⟧
print("")

# 4. More Complex Quantum Circuit - GHZ State
print("=== GHZ State Circuit ===")
𓀁 ghz_circuit = [
    "h 0",      # Hadamard on qubit 0  
    "cx 0 1",   # CNOT 0 -> 1
    "cx 1 2"    # CNOT 1 -> 2 (creates 3-qubit entanglement)
]
print("GHZ circuit gates:", ghz_circuit)

𓀀 ghz_job_id = submit_job("aeonmi_simulator", ghz_circuit, 2000)
print("GHZ job ID:", ghz_job_id)

𓀀 ghz_status = job_status(ghz_job_id)
print("GHZ job status:", ghz_status)

⦅ (ghz_status == "completed") ⦆ ⟦
    𓀀 ghz_results = job_results(ghz_job_id)
    print("GHZ State results:")
    print("  Measurement counts:", ghz_results["counts"])
    print("  State probabilities:", ghz_results["probabilities"])
⟧
print("")

# 5. Hardware Provider Information
print("=== Hardware Provider Information ===")
print("Available Providers:")
print("  • IBM Quantum - Superconducting qubits")
