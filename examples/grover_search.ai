⍝ Grover's Algorithm — Quantum Database Search
⍝ Problem: Find the marked item in an unsorted database of N=4 items
⍝ Classical: O(N) — Quantum: O(√N)

import quantum;

⍝ Oracle: marks item |11⟩ (index 3)
fn oracle(qc) {
    qc.cz(0, 1);  ⍝ phase flip on |11⟩
    return qc;
}

⍝ Diffusion operator (inversion about average)
fn diffusion(qc) {
    qc.h(0); qc.h(1);
    qc.x(0); qc.x(1);
    qc.cz(0, 1);
    qc.x(0); qc.x(1);
    qc.h(0); qc.h(1);
    return qc;
}

fn main() {
    ⍝ Initialize 2-qubit circuit (4 states)
    let qc = quantum.circuit(2);
    
    ⍝ Superposition
    qc.h(0);
    qc.h(1);
    
    ⍝ Grover iteration (1 iteration for N=4)
    qc = oracle(qc);
    qc = diffusion(qc);
    
    ⍝ Measure
    qc.measure_all();
    
    ⍝ Execute
    let result = quantum.execute(qc, shots: 1024);
    
    print("Grover Search Results:");
    print(result.counts());
    print("Most likely state: " + result.max_count_state());
    
    ⍝ Export circuit
    quantum.export_qasm(qc, "grover_search.qasm");
    
    return 0;
}

return main();