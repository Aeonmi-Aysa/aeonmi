// P1-19: Array method test (JS backend)
let arr = [1, 2, 3];
log(arr);              // [1, 2, 3]

arr.push(4);
log(arr);              // [1, 2, 3, 4]

let popped = arr.pop();
log(popped);           // 4
log(arr);              // [1, 2, 3]

let joined = arr.join("-");
log(joined);           // 1-2-3
