// genesis.ai — Phase 1.5 Genesis Glyph demonstration
// Showcases ⧉ (glyph array), ‥ (element separator), … (spread), ↦ (bind)

// === Genesis Glyph Arrays ⧉ ===
// ⧉ opens and closes a glyph-array literal; ‥ separates elements
let nums = ⧉1‥2‥3‥4‥5⧉;
log("Glyph array: " + nums.length + " elements");

// Iteration over a glyph array
let total = 0;
for n in nums {
    total = total + n;
}
log("Sum: " + total);

// === Spread Operator … ===
// …expr spreads a value — useful for passing arrays as arguments
let base = [10, 20, 30];
let extended = base.concat([40, 50]);
log("Extended length: " + extended.length);

// === Binding Projection ↦ ===
// name ↦ expr binds expr to name in the current scope
let greeting ↦ f"Hello, {total}!";
log(greeting);

// === f-String Interpolation (Phase 1) ===
let name = "Aeonmi";
let version = "1.0";
let banner = f"🔮 {name} v{version} — Genesis Glyphs Active";
log(banner);

// === for-in Iteration (Phase 1) ===
let languages = ["Rust", "Aeonmi", "Python"];
for lang in languages {
    log(f"  ▸ {lang}");
}

// === Array is_empty (Phase 1) ===
let empty = [];
let full = [1, 2];
log("empty.is_empty(): " + empty.is_empty());
log("full.is_empty(): " + full.is_empty());

// === File I/O (Phase 3) ===
write_file("/tmp/genesis_output.txt", f"Generated by Aeonmi {version}\n");
let content = read_file("/tmp/genesis_output.txt");
log("File content: " + content);
log("File exists: " + file_exists("/tmp/genesis_output.txt"));

log("");
log("✅ Genesis glyph demonstration complete.");
