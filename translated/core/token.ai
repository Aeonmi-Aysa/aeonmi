⍝ token record = [kind, lexeme, line, column]
◯ token_new⟨kind, lexeme, line, column⟩ {
    let t = [];
    t.push(kind);
    t.push(lexeme);
    t.push(line);
    t.push(column);
    return t;
}

◯ token_kind⟨t⟩ { return t.slice(0,1).pop(); }
◯ token_lexeme⟨t⟩ { return t.slice(1,2).pop(); }
◯ token_line⟨t⟩ { return t.slice(2,3).pop(); }
◯ token_column⟨t⟩ { return t.slice(3,4).pop(); }
