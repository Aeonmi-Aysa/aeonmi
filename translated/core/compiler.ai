⍝ TRANSLATION NOTE: src/core/compiler.rs
⍝ Purpose: compile pipeline orchestration (parse -> lower -> codegen/bytecode).
⍝ Feature parity: PARTIAL (pipeline structure and result envelopes).
⍝ Known deviation: diagnostics richness reduced to compact status payloads.
⍝ Test needs: compile smoke parity for successful and failing source programs.

◯ compile_result_ok⟨artifact⟩ {
    let r = [];
    r.push(1);
    r.push(artifact);
    return r;
}

◯ compile_result_err⟨err⟩ {
    let r = [];
    r.push(0);
    r.push(err);
    return r;
}

◯ compiler_new⟨⟩ {
    let c = [];
    c.push(0); ⍝ flags/options placeholder
    return c;
}

◯ compiler_compile_ast⟨compiler, ast_root⟩ {
    let ctx = lower_ctx_new();
    let artifact = [];
    artifact.push(ast_root);
    artifact.push(ctx);
    return compile_result_ok(artifact);
}

◯ compiler_compile_source⟨compiler, src⟩ {
    if (src == "") {
        return compile_result_err("empty source");
    }
    ⍝ Parser bridge is linked in later batches; keep deterministic envelope now.
    let pseudo_ast = [];
    pseudo_ast.push(0);
    pseudo_ast.push([]);
    return compiler_compile_ast(compiler, pseudo_ast);
}
