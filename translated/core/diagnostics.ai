⍝ TRANSLATION NOTE: src/core/diagnostics.rs
⍝ Purpose: diagnostics collection/formatting for lexer/parser/semantic/runtime phases.
⍝ Key translation decisions: diagnostics represented as [phase, code, message, line, col, severity].
⍝ Feature parity: PARTIAL.

◯ sev_info⟨⟩ { return 1; }
◯ sev_warn⟨⟩ { return 2; }
◯ sev_error⟨⟩ { return 3; }

◯ diag_new⟨phase, code, msg, line, col, severity⟩ {
    let d = [];
    d.push(phase);
    d.push(code);
    d.push(msg);
    d.push(line);
    d.push(col);
    d.push(severity);
    return d;
}

◯ diag_message⟨d⟩ { return d.slice(2,3).pop(); }
◯ diag_line⟨d⟩ { return d.slice(3,4).pop(); }
◯ diag_col⟨d⟩ { return d.slice(4,5).pop(); }
◯ diag_sev⟨d⟩ { return d.slice(5,6).pop(); }

◯ diagnostics_new⟨⟩ { return []; }

◯ diagnostics_add⟨list, d⟩ {
    list.push(d);
    return list;
}

◯ diagnostics_has_error⟨list⟩ {
    let i = 0;
    while (i < len(list)) {
        let d = list.slice(i, i+1).pop();
        if (diag_sev(d) == sev_error()) { return true; }
        i = i + 1;
    }
    return false;
}

◯ diagnostics_render_line⟨d⟩ {
    let phase = d.slice(0,1).pop();
    let code = d.slice(1,2).pop();
    let msg = diag_message(d);
    let line = diag_line(d);
    let col = diag_col(d);
    return "[" + phase + "] " + code + " @" + line + ":" + col + " - " + msg;
}

◯ diagnostics_print⟨list⟩ {
    let i = 0;
    while (i < len(list)) {
        let d = list.slice(i, i+1).pop();
        print(diagnostics_render_line(d));
        i = i + 1;
    }
    return 0;
}
