}

// === VOICE DEMO MODE ===
quantum voice_demo VoiceMotherAIDemo {
    
    async function main() {
        log("🎤 Mother AI Voice Demo Mode");
        log("============================");
        log("");
        
        // Initialize Mother AI with voice enabled
        let mut mother_ai = MotherAI::new();
        let mut nl_interface = NaturalLanguageInterface::new(mother_ai);
        
        // Enable voice mode
        nl_interface.enable_voice_mode();
        
        println!("🎤 Voice mode active! Speak naturally to Mother AI.");
        println!("🔊 Mother AI will respond with both text and voice.");
        println!("Say 'stop listening' to switch to text mode.");
        println!("Say 'goodbye' to exit.");
        println!("");
        
        // Start voice interaction
        await nl_interface.conversation_loop();
    }
}

