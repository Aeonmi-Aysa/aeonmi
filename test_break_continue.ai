// Break/Continue Test
// Expected output: 4
// Explanation: Loop breaks when i=5, so i runs 0..4
// continue skips even i, so it adds 1 + 3 = 4

let sum = 0;
for (let i = 0; i < 10; i = i + 1) {
    if (i == 5) {
        break;
    }
    if (i % 2 == 0) {
        continue;
    }
    sum = sum + i;
}
log(sum);
