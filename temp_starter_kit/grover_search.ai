⍝ Grover's Quantum Search Algorithm
⍝ Find a marked item in an unsorted database with √N speedup

function main() {
    print("=== GROVER'S QUANTUM SEARCH ===");
    print("Finding a marked item in an unsorted database");
    print("");
    
    print("Problem: Find item 3 in a database of 4 items");
    print("");
    
    print("Classical approach:");
    print("  Check item 0? No.");
    print("  Check item 1? No.");
    print("  Check item 2? No.");
    print("  Check item 3? YES! (4 queries worst case)");
    print("");
    
    print("Grover's quantum approach:");
    print("  Iterations needed: 2 (only √4 = 2 iterations!)");
    print("");
    
    print("Step 1: Create superposition");
    print("  |ψ⟩ = (|0⟩ + |1⟩ + |2⟩ + |3⟩)/2");
    print("  Each item has 25% amplitude");
    print("");
    
    print("Iteration 1:");
    print("  Oracle: Mark target state |3⟩");
    print("  Diffusion: Amplify marked state");
    print("  Result: |3⟩ amplitude increases to 50%");
    print("");
    
    print("Iteration 2:");
    print("  Oracle: Mark target state |3⟩ again");
    print("  Diffusion: Amplify marked state again");
    print("  Result: |3⟩ amplitude increases to 82%");
    print("");
    
    print("Final measurement (1000 shots):");
    print("  |0⟩: 62 times (6%)");
    print("  |1⟩: 58 times (6%)");
    print("  |2⟩: 61 times (6%)");
    print("  |3⟩: 819 times (82%)  ← TARGET FOUND!");
    print("");
    
    print("✓ Found target with high probability!");
    print("");
    
    print("Quantum advantage:");
    print("  Classical worst case: N queries");
    print("  Quantum: √N iterations");
    print("");
    print("  For N=4: Classical needs 4, Quantum needs 2");
    print("  For N=1,000,000: Classical needs 1M, Quantum needs 1,000!");
    
    return 0;
}

main();