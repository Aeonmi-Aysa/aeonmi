⍝ plan.ai — Goal planning: decompose objectives into tracked steps
⍝ Plan = flat array, 4 fields per entry: [goal_id, priority, status, tag]
⍝ status: 0=pending  1=done  2=cancelled
⍝ Functions: 11 total, no imports

◯ plan_add⟨p, goal_id, priority, tag⟩ {
    ⍝ Append a new goal entry
    let result = [];
    let i = 0; let total = len(p);
    while (i < total) { result.push(p.slice(i, i+1).pop()); i = i + 1; }
    result.push(goal_id);
    result.push(priority);
    result.push(0);
    result.push(tag);
    return result;
}

◯ plan_cancel⟨p, idx⟩ {
    ⍝ Mark entry at idx as cancelled (status=2)
    let total = len(p) / 4;
    let result = [];
    let i = 0;
    while (i < total) {
        let base = i * 4;
        result.push(p.slice(base, base+1).pop());
        result.push(p.slice(base+1, base+2).pop());
        if (i == idx) { result.push(2); } else { result.push(p.slice(base+2, base+3).pop()); }
        result.push(p.slice(base+3, base+4).pop());
        i = i + 1;
    }
    return result;
}

◯ plan_count⟨p⟩ {
    return len(p) / 4;
}

◯ plan_done⟨p, idx⟩ {
    ⍝ Mark entry at idx as done (status=1)
    let total = len(p) / 4;
    let result = [];
    let i = 0;
    while (i < total) {
        let base = i * 4;
        result.push(p.slice(base, base+1).pop());
        result.push(p.slice(base+1, base+2).pop());
        if (i == idx) { result.push(1); } else { result.push(p.slice(base+2, base+3).pop()); }
        result.push(p.slice(base+3, base+4).pop());
        i = i + 1;
    }
    return result;
}

◯ plan_done_count⟨p⟩ {
    let total = len(p) / 4;
    let c = 0; let i = 0;
    while (i < total) {
        let st = p.slice(i*4+2, i*4+3).pop();
        if (st == 1) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

◯ plan_goal⟨p, idx⟩ {
    return p.slice(idx*4, idx*4+1).pop();
}

◯ plan_new⟨⟩ {
    return [];
}

◯ plan_next⟨p⟩ {
    ⍝ Index of highest-priority pending entry (-1 if none)
    let total = len(p) / 4;
    let best_idx = -1;
    let best_pri = -1;
    let i = 0;
    while (i < total) {
        let st = p.slice(i*4+2, i*4+3).pop();
        let pri = p.slice(i*4+1, i*4+2).pop();
        if (st == 0) {
            if (pri > best_pri) {
                best_pri = pri;
                best_idx = i;
            }
        }
        i = i + 1;
    }
    return best_idx;
}

◯ plan_pending_count⟨p⟩ {
    let total = len(p) / 4;
    let c = 0; let i = 0;
    while (i < total) {
        let st = p.slice(i*4+2, i*4+3).pop();
        if (st == 0) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

◯ plan_priority⟨p, idx⟩ {
    return p.slice(idx*4+1, idx*4+2).pop();
}

◯ plan_status⟨p, idx⟩ {
    return p.slice(idx*4+2, idx*4+3).pop();
}

◯ main⟨⟩ {
    print("plan module loaded — new add count goal priority status done cancel next pending_count done_count");
}
