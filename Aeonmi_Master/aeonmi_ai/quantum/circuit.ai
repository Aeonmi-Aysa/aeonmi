⍝ circuit.ai — Quantum circuit descriptor (flat array)
⍝ Layout: [n_qubits, type0, target0, ctrl0, type1, target1, ctrl1, ...]
⍝ Gate types: 0=H 1=X 2=Y 3=Z 4=CX 5=S 6=T 7=MEASURE
⍝ Functions: 10 total, no imports

◯ circ_add⟨c, gtype, target, ctrl⟩ {
    ⍝ Append a gate descriptor (3 fields) to circuit c
    let r = [];
    let i = 0;
    let total = len(c);
    while (i < total) {
        r.push(c.slice(i, i + 1).pop());
        i = i + 1;
    }
    r.push(gtype);
    r.push(target);
    r.push(ctrl);
    return r;
}

◯ circ_count⟨c⟩ {
    ⍝ Number of gates in circuit
    return (len(c) - 1) / 3;
}

◯ circ_ctrl⟨c, i⟩ {
    ⍝ Control qubit for gate i (-1 = single-qubit)
    return c.slice(1 + i * 3 + 2, 1 + i * 3 + 3).pop();
}

◯ circ_new⟨n_qubits⟩ {
    ⍝ Create empty circuit with n_qubits qubits
    let r = [];
    r.push(n_qubits);
    return r;
}

◯ circ_qubits⟨c⟩ {
    ⍝ Number of qubits in this circuit
    return c.slice(0, 1).pop();
}

◯ circ_target⟨c, i⟩ {
    ⍝ Target qubit for gate i
    return c.slice(1 + i * 3 + 1, 1 + i * 3 + 2).pop();
}

◯ circ_type⟨c, i⟩ {
    ⍝ Gate type int for gate i
    return c.slice(1 + i * 3, 1 + i * 3 + 1).pop();
}

◯ circ_type_cx⟨⟩ { return 4; }
◯ circ_type_h⟨⟩  { return 0; }
◯ circ_type_x⟨⟩  { return 1; }

◯ main⟨⟩ {
    let c = circ_new(2);
    c = circ_add(c, circ_type_h(), 0, -1);
    c = circ_add(c, circ_type_cx(), 0, 1);
    print("circuit: qubits=", circ_qubits(c), "gates=", circ_count(c));
}
