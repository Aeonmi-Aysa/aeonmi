⍝ agent_demo.ai — Integrated agent runtime demo (flat, no imports)
⍝ Demonstrates: planning, action selection, decision making, net messaging
⍝ All helpers inlined using a_/b_/c_/d_ prefix for alphabetical ordering
⍝ Functions: 12 total

◯ a_act_cheapest⟨reg⟩ {
    ⍝ Name_id of cheapest enabled action in registry [name,type,cost,enabled, ...]
    let total = len(reg) / 4;
    let best_name = -1; let best_cost = -1;
    let i = 0;
    while (i < total) {
        let en = reg.slice(i*4+3, i*4+4).pop();
        let c  = reg.slice(i*4+2, i*4+3).pop();
        if (en == 1) {
            if (best_name == -1) {
                best_name = reg.slice(i*4, i*4+1).pop();
                best_cost = c;
            } else {
                if (c < best_cost) {
                    best_cost = c; best_name = reg.slice(i*4, i*4+1).pop();
                }
            }
        }
        i = i + 1;
    }
    return best_name;
}

◯ a_act_register⟨reg, name_id, type_id, cost⟩ {
    let result = [];
    let i = 0; let total = len(reg);
    while (i < total) { result.push(reg.slice(i, i+1).pop()); i = i + 1; }
    result.push(name_id); result.push(type_id); result.push(cost); result.push(1);
    return result;
}

◯ b_dec_should_act⟨pending, actions⟩ {
    if (pending > 0) { if (actions > 0) { return true; } }
    return false;
}

◯ b_plan_add⟨p, goal_id, priority⟩ {
    let result = [];
    let i = 0; let total = len(p);
    while (i < total) { result.push(p.slice(i, i+1).pop()); i = i + 1; }
    result.push(goal_id); result.push(priority); result.push(0); result.push(0);
    return result;
}

◯ b_plan_next⟨p⟩ {
    ⍝ Index of highest-priority pending goal
    let total = len(p) / 4;
    let best_idx = -1; let best_pri = -1;
    let i = 0;
    while (i < total) {
        let st  = p.slice(i*4+2, i*4+3).pop();
        let pri = p.slice(i*4+1, i*4+2).pop();
        if (st == 0) {
            if (pri > best_pri) { best_pri = pri; best_idx = i; }
        }
        i = i + 1;
    }
    return best_idx;
}

◯ b_plan_pending⟨p⟩ {
    let total = len(p) / 4; let c = 0; let i = 0;
    while (i < total) {
        if (p.slice(i*4+2, i*4+3).pop() == 0) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

◯ c_msg_send⟨box, from_id, to_id, type_id, payload, ts⟩ {
    let result = [];
    let i = 0; let total = len(box);
    while (i < total) { result.push(box.slice(i, i+1).pop()); i = i + 1; }
    result.push(from_id); result.push(to_id); result.push(type_id);
    result.push(payload); result.push(ts);
    return result;
}

◯ c_plan_done⟨p, idx⟩ {
    let total = len(p) / 4;
    let result = []; let i = 0;
    while (i < total) {
        let base = i * 4;
        result.push(p.slice(base, base+1).pop());
        result.push(p.slice(base+1, base+2).pop());
        if (i == idx) { result.push(1); } else { result.push(p.slice(base+2, base+3).pop()); }
        result.push(p.slice(base+3, base+4).pop());
        i = i + 1;
    }
    return result;
}

◯ d_run_agent_loop⟨plan, actions, cycle_limit⟩ {
    ⍝ Run agent loop: pick next goal, select action, execute, repeat
    let mailbox = [];
    let cycle = 0;
    while (cycle < cycle_limit) {
        let pending = b_plan_pending(plan);
        let act_count = len(actions) / 4;
        if (b_dec_should_act(pending, act_count) == true) {
            let next_idx = b_plan_next(plan);
            let goal_id = plan.slice(next_idx*4, next_idx*4+1).pop();
            let act_name = a_act_cheapest(actions);
            ⍝ Execute: mark goal done, send completion message
            plan = c_plan_done(plan, next_idx);
            mailbox = c_msg_send(mailbox, 1, 99, 5, goal_id, cycle);
        }
        cycle = cycle + 1;
    }
    let result = [];
    result.push(b_plan_pending(plan));
    result.push(len(mailbox) / 5);
    return result;
}

◯ main⟨⟩ {
    print("=== AGENT DEMO ===");

    ⍝ Build plan: 3 goals with priorities
    let plan = [];
    plan = b_plan_add(plan, 1001, 8);
    plan = b_plan_add(plan, 1002, 5);
    plan = b_plan_add(plan, 1003, 9);
    print("Initial plan: pending=", b_plan_pending(plan), "next=", b_plan_next(plan));

    ⍝ Build action registry
    let actions = [];
    actions = a_act_register(actions, 201, 1, 10);
    actions = a_act_register(actions, 202, 2, 5);
    actions = a_act_register(actions, 203, 1, 8);
    print("Actions: count=", len(actions)/4, "cheapest=", a_act_cheapest(actions));

    ⍝ Decision check
    print("Should act?", b_dec_should_act(b_plan_pending(plan), len(actions)/4));

    ⍝ Run agent loop for 5 cycles
    let result = d_run_agent_loop(plan, actions, 5);
    let final_pending = result.slice(0, 1).pop();
    let msgs_sent = result.slice(1, 2).pop();
    print("After 5 cycles: pending=", final_pending, "messages_sent=", msgs_sent);

    if (final_pending == 0) {
        if (msgs_sent == 3) {
            print("=== PASS ===");
        }
    }
}
