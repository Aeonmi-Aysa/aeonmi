⍝ router_test.ai — Tests for swarm/router.ai
import { a_route_find, route_add, route_count, route_del, route_dispatch, route_from_at, route_has, route_new, route_to_at, route_topic_at, route_update } from "./router";

◯ check⟨label, got, expected⟩ {
    if (got == expected) {
        print("PASS:", label);
        return 1;
    }
    print("FAIL:", label, "got=", got, "expected=", expected);
    return 0;
}

◯ main⟨⟩ {
    let p = 0;

    ⍝ route_new / route_count
    let rt = route_new(5);
    p = p + check("new count=0", route_count(rt), 0);

    ⍝ route_add
    rt = route_add(rt, 0, 1, 10);
    rt = route_add(rt, 0, 2, 20);
    rt = route_add(rt, 1, 3, 10);
    rt = route_add(rt, 2, 4, 30);
    p = p + check("count=4", route_count(rt), 4);

    ⍝ route_has
    p = p + check("has(0,10)=1", route_has(rt, 0, 10), 1);
    p = p + check("has(0,20)=1", route_has(rt, 0, 20), 1);
    p = p + check("has(0,99)=0", route_has(rt, 0, 99), 0);
    p = p + check("has(1,10)=1", route_has(rt, 1, 10), 1);

    ⍝ route_dispatch
    p = p + check("dispatch(0,10)=1", route_dispatch(rt, 0, 10, -1), 1);
    p = p + check("dispatch(0,20)=2", route_dispatch(rt, 0, 20, -1), 2);
    p = p + check("dispatch(1,10)=3", route_dispatch(rt, 1, 10, -1), 3);
    p = p + check("dispatch(0,99)=-1", route_dispatch(rt, 0, 99, -1), -1);

    ⍝ route_from_at / route_to_at / route_topic_at
    p = p + check("from_at(0)=0", route_from_at(rt, 0), 0);
    p = p + check("to_at(0)=1", route_to_at(rt, 0), 1);
    p = p + check("topic_at(0)=10", route_topic_at(rt, 0), 10);

    ⍝ a_route_find
    p = p + check("find(0,10)=1", a_route_find(rt, 0, 10), 1);
    p = p + check("find(0,99)=-1", a_route_find(rt, 0, 99), -1);

    ⍝ route_update
    rt = route_update(rt, 0, 5, 10);
    p = p + check("update(0,10)->5", route_dispatch(rt, 0, 10, -1), 5);
    p = p + check("count unchanged=4", route_count(rt), 4);

    ⍝ route_del
    rt = route_del(rt, 0, 20);
    p = p + check("after del count=3", route_count(rt), 3);
    p = p + check("has(0,20) after del=0", route_has(rt, 0, 20), 0);

    print("router tests passed:", p, "/ 18");
}
