// hive_runner.ai — Aeonmi Unified Hive Mind
// Runs all agents in sequence, emits HIVE_STATE lines for dashboard parsing
// Called by api_hive_run() in dashboard.py
// Agents: Oracle, Hype, Closer, Devil, Quantum Reasoner, Conductor
// Mother reads hive_state.json and uses scores as context

function fn_extract_count(result_json, key) {
    let needle = "\"" + key + "\"";
    let start = find(result_json, needle);
    if start < 0 { return 0; }
    let i = start + len(needle);
    while i < len(result_json) {
        if char_at(result_json, i) == ":" { i = i + 1; break; }
        i = i + 1;
    }
    if i >= len(result_json) { return 0; }
    while i < len(result_json) {
        let ch = char_at(result_json, i);
        if ch == " " { i = i + 1; } else { break; }
    }
    let digits = "";
    while i < len(result_json) {
        let ch = char_at(result_json, i);
        if ch >= "0" {
            if ch <= "9" { digits = digits + ch; i = i + 1; } else { break; }
        } else { break; }
    }
    if len(digits) == 0 { return 0; }
    return int(digits);
}

function fn_round3(x) { return floor(x * 1000.0) / 1000.0; }

function fn_clamp_score(s) {
    if s < 0 { return 0; }
    if s > 100 { return 100; }
    return int(s);
}

// ── ORACLE: quantum QRNG + Bell coherence ───────────────────────────────────
function fn_agent_oracle() {
    let live = quantum_check();
    let score = 50;
    let coherence = 0.5;

    if live == 1 {
        let r1 = quantum_run("1 1 32 2 0 0 -1 7 0 0");
        let c1 = fn_extract_count(r1, "1");
        let r2 = quantum_run("2 2 128 4 0 0 -1 4 1 0 7 0 0 7 1 1");
        let c00 = fn_extract_count(r2, "00");
        let c11 = fn_extract_count(r2, "11");
        coherence = (c00 + c11) / 128.0;
        let base_score = (c1 / 32.0) * 100.0;
        let boost = (coherence - 0.5) * 20.0;
        score = fn_clamp_score(base_score + boost);
    }

    log("HIVE_STATE:oracle_sc:" + score);
    log("HIVE_STATE:oracle_coherence:" + fn_round3(coherence));
    log("HIVE_STATE:oracle_live:" + live);
    return score;
}

// ── HYPE: momentum + quantum-seeded trend ───────────────────────────────────
function fn_agent_hype() {
    let live = quantum_check();
    let momentum = 60;
    let trend_boost = 20;

    if live == 1 {
        // QRNG seeds trend direction
        let r = quantum_run("1 1 8 2 0 0 -1 7 0 0");
        let ones = fn_extract_count(r, "1");
        trend_boost = (ones / 8.0) * 40;
    }

    let score = fn_clamp_score(momentum + trend_boost);
    log("HIVE_STATE:hype_sc:" + score);
    return score;
}

// ── CLOSER: intent + conviction ─────────────────────────────────────────────
function fn_agent_closer() {
    let live = quantum_check();
    let intent = 55;
    let conviction_boost = 25;

    if live == 1 {
        // Bell parity seeds conviction
        let r = quantum_run("2 2 32 4 0 0 -1 4 1 0 7 0 0 7 1 1");
        let c11 = fn_extract_count(r, "11");
        conviction_boost = (c11 / 32.0) * 45;
    }

    let score = fn_clamp_score(intent + conviction_boost);
    log("HIVE_STATE:close_sc:" + score);
    return score;
}

// ── DEVIL: risk adversarial challenge ───────────────────────────────────────
function fn_agent_devil() {
    let live = quantum_check();
    let volatility = 40;
    let exposure_boost = 15;

    if live == 1 {
        // Low Bell coherence = higher risk signal
        let r = quantum_run("2 2 64 4 0 0 -1 4 1 0 7 0 0 7 1 1");
        let c00 = fn_extract_count(r, "00");
        let c11 = fn_extract_count(r, "11");
        let coherence = (c00 + c11) / 64.0;
        // Invert: low coherence = high risk
        exposure_boost = (1.0 - coherence) * 40;
    }

    let score = fn_clamp_score(volatility + exposure_boost);
    log("HIVE_STATE:risk_sc:" + score);
    return score;
}

// ── QUANTUM REASONER: GHZ coherence → reasoning mode ────────────────────────
function fn_agent_reasoner() {
    let live = quantum_check();
    let mode = "SYSTEMATIC";
    let branch_code = 0;
    let ghz_coh = 0.5;

    if live == 1 {
        let r_ghz = quantum_run("3 3 64 6 0 0 -1 4 1 0 4 2 0 7 0 0 7 1 1 7 2 2");
        let c000 = fn_extract_count(r_ghz, "000");
        let c111 = fn_extract_count(r_ghz, "111");
        ghz_coh = (c000 + c111) / 64.0;

        let r_bell = quantum_run("2 2 32 4 0 0 -1 4 1 0 7 0 0 7 1 1");
        let b11 = fn_extract_count(r_bell, "11");
        let b00 = fn_extract_count(r_bell, "00");
        let bell_parity = 0;
        if b11 > b00 { bell_parity = 1; }

        let r_qrng = quantum_run("1 1 1 2 0 0 -1 7 0 0");
        let branch_bit = fn_extract_count(r_qrng, "1");

        let ghz_mode = 0;
        if ghz_coh > 0.7 { ghz_mode = 1; }
        branch_code = ghz_mode * 4 + bell_parity * 2 + branch_bit;

        if ghz_coh > 0.7 {
            if branch_bit == 1 { mode = "EXPLORATORY"; } else { mode = "DEEP_SCAN"; }
        } else if ghz_coh < 0.4 {
            mode = "CONSERVATIVE";
        } else {
            if bell_parity == 1 { mode = "LATERAL"; } else { mode = "SYSTEMATIC"; }
        }
    }

    log("HIVE_STATE:reasoner_mode:" + mode);
    log("HIVE_STATE:reasoner_branch:" + branch_code);
    log("HIVE_STATE:reasoner_coherence:" + fn_round3(ghz_coh));
    return mode;
}

// ── CONDUCTOR: synthesize all scores + quantum coherence ────────────────────
function fn_agent_conductor(oracle, hype, closer, risk) {
    let q_score = 0.5;

    if file_exists("qc_signals.json") {
        let txt = read_file("qc_signals.json");
        // Simple float extract
        let needle = "\"fused_quantum_score\"";
        let start = find(txt, needle);
        if start >= 0 {
            let i = start + len(needle);
            while i < len(txt) {
                if char_at(txt, i) == ":" { i = i + 1; break; }
                i = i + 1;
            }
            while i < len(txt) {
                let ch = char_at(txt, i);
                if ch == " " { i = i + 1; } else { break; }
            }
            let num = "";
            while i < len(txt) {
                let ch = char_at(txt, i);
                let is_d = (ch >= "0") && (ch <= "9");
                if is_d || ch == "." { num = num + ch; i = i + 1; } else { break; }
            }
            if len(num) > 0 { q_score = float(num); }
        }
    }

    let weighted = (oracle * 0.35) + (hype * 0.25) + (closer * 0.25) + ((100 - risk) * 0.15);

    let q_mod = 0.0;
    if q_score > 0.7 { q_mod = 8.0; }
    if q_score < 0.3 { q_mod = -8.0; }
    weighted = weighted + q_mod;

    let rec = 1;
    if weighted > 75 { rec = 3; }
    else if weighted > 55 { rec = 2; }
    else if weighted < 30 { rec = 0; }

    log("HIVE_STATE:conductor_rec:" + rec);
    log("HIVE_STATE:weighted:" + fn_round3(weighted));
    log("HIVE_STATE:q_score:" + fn_round3(q_score));
    log("HIVE_STATE:q_modifier:" + fn_round3(q_mod));
    return rec;
}

// ── MAIN HIVE CYCLE ──────────────────────────────────────────────────────────
function main() {
    print("=== AEONMI HIVE MIND — FULL CYCLE ===");
    let live = quantum_check();
    if live == 1 { print("Quantum: LIVE (Qiskit Aer)"); } else { print("Quantum: DRY-RUN"); }
    print("");

    let oracle  = fn_agent_oracle();
    let hype    = fn_agent_hype();
    let closer  = fn_agent_closer();
    let risk    = fn_agent_devil();
    let mode    = fn_agent_reasoner();
    let rec     = fn_agent_conductor(oracle, hype, closer, risk);

    let rec_label = "HOLD";
    if rec == 0 { rec_label = "ABORT"; }
    if rec == 2 { rec_label = "PROCEED"; }
    if rec == 3 { rec_label = "ACCELERATE"; }

    print("");
    print("=== HIVE SUMMARY ===");
    print("Oracle:   " + oracle);
    print("Hype:     " + hype);
    print("Closer:   " + closer);
    print("Risk:     " + risk);
    print("Reason:   " + mode);
    print("Verdict:  " + rec_label);

    log("HIVE_STATE:cycle_ok:1");
    return 0;
}

main();
