⍝ parser_test.ai — Aeonmi self-hosted parser tests v0.1
⍝ Import 12 fns from parser.ai + check + main = 14 total (at limit)
⍝ NO lexer import — token streams hand-constructed to stay within budget.
⍝ Token type reference (from lexer.ai):
⍝   1=Number  3=Ident  4=Let  6=Else  8=Return
⍝   24=EqEq  30=Assign  36=Semi  99=EOF
⍝ AST node types:
⍝   1=Number  3=Ident  4=BinOp  6=LetStmt  10=ReturnStmt
⍝ Node layout: [type, f0, f1, f2] × N  (flat, 4 fields each)

import { par_parse, par_node_type, par_node_f0 } from "./parser";

◯ check⟨label, got, want⟩ {
    if (got == want) { return 0; }
    print(label);
    print(got);
    print(want);
    return 1;
}

◯ main⟨⟩ {
    ⍝ ── TEST 1: let x = 1; ────────────────────────────────────────────────
    ⍝ src = "let x = 1;"  (len=10)
    ⍝ tok[0]=(4,0,3) let   tok[1]=(3,4,1) x   tok[2]=(30,6,1) =
    ⍝ tok[3]=(1,8,1) 1     tok[4]=(36,9,1) ;   tok[5]=(99,10,0) EOF
    let src1 = "let x = 1;";
    let tok1 = [4, 0, 3,  3, 4, 1,  30, 6, 1,  1, 8, 1,  36, 9, 1,  99, 10, 0];
    let nd1  = par_parse(src1, tok1);

    check("t1-nd-len",     len(nd1),              8);
    check("t1-num-type",   par_node_type(nd1, 0), 1);
    check("t1-num-f0",     par_node_f0(nd1, 0),   "1");
    check("t1-let-type",   par_node_type(nd1, 1), 6);
    check("t1-let-f0",     par_node_f0(nd1, 1),   "x");

    ⍝ ── TEST 2: return 42; ────────────────────────────────────────────────
    ⍝ src = "return 42;"  (len=10)
    ⍝ tok[0]=(8,0,6) return  tok[1]=(1,7,2) 42  tok[2]=(36,9,1) ;  tok[3]=(99,10,0) EOF
    let src2 = "return 42;";
    let tok2 = [8, 0, 6,  1, 7, 2,  36, 9, 1,  99, 10, 0];
    let nd2  = par_parse(src2, tok2);

    check("t2-nd-len",     len(nd2),              8);
    check("t2-num-type",   par_node_type(nd2, 0), 1);
    check("t2-num-f0",     par_node_f0(nd2, 0),   "42");
    check("t2-ret-type",   par_node_type(nd2, 1), 10);
    check("t2-ret-f0",     par_node_f0(nd2, 1),   0);

    ⍝ ── TEST 3: a == b; ───────────────────────────────────────────────────
    ⍝ src = "a == b;"  (len=7)
    ⍝ tok[0]=(3,0,1) a   tok[1]=(24,2,2) ==  tok[2]=(3,5,1) b
    ⍝ tok[3]=(36,6,1) ;  tok[4]=(99,7,0) EOF
    let src3 = "a == b;";
    let tok3 = [3, 0, 1,  24, 2, 2,  3, 5, 1,  36, 6, 1,  99, 7, 0];
    let nd3  = par_parse(src3, tok3);

    check("t3-nd-len",     len(nd3),              12);
    check("t3-a-type",     par_node_type(nd3, 0), 3);
    check("t3-a-f0",       par_node_f0(nd3, 0),   "a");
    check("t3-b-type",     par_node_type(nd3, 1), 3);
    check("t3-b-f0",       par_node_f0(nd3, 1),   "b");
    check("t3-binop-type", par_node_type(nd3, 2), 4);
    check("t3-binop-op",   par_node_f0(nd3, 2),   24);

    print("=== PASS ===");
}
