⍝ test_math_builtins.ai — tests for all math builtins + stdlib/math.ai

⍝ ── Constants ────────────────────────────────────────────────────────────────
print("=== Math Constants ===");
assert(abs(PI - 3.14159265358979) < 0.00001, "PI wrong");
assert(abs(E  - 2.71828182845905) < 0.00001, "E wrong");
assert(abs(TAU - PI * 2) < 0.00001, "TAU wrong");
print("  PI=" + toString(PI) + " E=" + toString(E) + " TAU=" + toString(TAU));

⍝ ── sqrt ─────────────────────────────────────────────────────────────────────
print("=== sqrt ===");
assert_eq(sqrt(4), 2, "sqrt(4)!=2");
assert_eq(sqrt(9), 3, "sqrt(9)!=3");
assert(abs(sqrt(2) - 1.41421356) < 0.00001, "sqrt(2)");

⍝ ── trig ─────────────────────────────────────────────────────────────────────
print("=== trig ===");
assert(abs(sin(0))   < 0.00001, "sin(0)!=0");
assert(abs(cos(0)-1) < 0.00001, "cos(0)!=1");
assert(abs(sin(PI))  < 0.00001, "sin(PI)!=0");
assert(abs(tan(PI/4)-1) < 0.00001, "tan(PI/4)!=1");

⍝ ── floor/ceil/round ─────────────────────────────────────────────────────────
print("=== floor/ceil/round ===");
assert_eq(floor(3.9), 3, "floor(3.9)");
assert_eq(ceil(3.1),  4, "ceil(3.1)");
assert_eq(round(3.5), 4, "round(3.5)");
assert_eq(round(3.4), 3, "round(3.4)");
assert_eq(floor(-1.1), -2, "floor(-1.1)");
assert_eq(ceil(-1.9),  -1, "ceil(-1.9)");

⍝ ── abs/exp/ln/log10/pow ─────────────────────────────────────────────────────
print("=== abs/exp/ln/log10/pow ===");
assert_eq(abs(-5), 5, "abs(-5)");
assert_eq(abs(5),  5, "abs(5)");
assert(abs(exp(1) - E) < 0.00001, "exp(1)!=E");
assert(abs(ln(E) - 1)  < 0.00001, "ln(E)!=1");
assert(abs(log10(100) - 2) < 0.00001, "log10(100)!=2");
assert_eq(pow(2, 10), 1024, "pow(2,10)");
assert_eq(pow(3, 3),  27,   "pow(3,3)");

⍝ ── min/max/clamp/lerp ───────────────────────────────────────────────────────
print("=== min/max/clamp/lerp ===");
assert_eq(min(3, 5),   3, "min(3,5)");
assert_eq(max(3, 5),   5, "max(3,5)");
assert_eq(clamp(10, 0, 5),  5,  "clamp upper");
assert_eq(clamp(-1, 0, 5),  0,  "clamp lower");
assert_eq(clamp(3,  0, 5),  3,  "clamp mid");
assert(abs(lerp(0, 10, 0.5) - 5) < 0.00001, "lerp(0,10,0.5)");
assert(abs(lerp(2, 4, 0.25) - 2.5) < 0.00001, "lerp(2,4,0.25)");

⍝ ── is_nan ───────────────────────────────────────────────────────────────────
print("=== is_nan ===");
assert(is_nan(NAN),  "NAN is nan");
assert(!is_nan(1.0), "1.0 not nan");

print("=== PASS ===");
