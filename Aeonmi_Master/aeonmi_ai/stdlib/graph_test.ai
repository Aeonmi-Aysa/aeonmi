⍝ graph_test.ai — Tests for stdlib/graph.ai
import { a_edge_at, graph_add_edge, graph_degree, graph_edge_count, graph_has_edge, graph_neighbors, graph_new, graph_node_count, graph_remove_edge, graph_total_weight, graph_weight } from "./graph";

◯ check⟨label, got, expected⟩ {
    if (got == expected) {
        print("PASS:", label);
        return 1;
    }
    print("FAIL:", label, "got=", got, "expected=", expected);
    return 0;
}

◯ main⟨⟩ {
    let p = 0;

    ⍝ graph_new / graph_node_count
    let g = graph_new(5);
    p = p + check("node_count=5", graph_node_count(g), 5);
    p = p + check("edge_count=0", graph_edge_count(g), 0);

    ⍝ graph_add_edge
    g = graph_add_edge(g, 0, 1, 10);
    g = graph_add_edge(g, 0, 2, 20);
    g = graph_add_edge(g, 1, 3, 15);
    g = graph_add_edge(g, 2, 3, 5);
    g = graph_add_edge(g, 3, 4, 8);
    p = p + check("edge_count=5", graph_edge_count(g), 5);

    ⍝ graph_has_edge
    p = p + check("has(0,1)=1", graph_has_edge(g, 0, 1), 1);
    p = p + check("has(0,2)=1", graph_has_edge(g, 0, 2), 1);
    p = p + check("has(1,0)=0", graph_has_edge(g, 1, 0), 0);
    p = p + check("has(4,0)=0", graph_has_edge(g, 4, 0), 0);

    ⍝ graph_weight
    p = p + check("weight(0,1)=10", graph_weight(g, 0, 1), 10);
    p = p + check("weight(0,2)=20", graph_weight(g, 0, 2), 20);
    p = p + check("weight(99,0)=0", graph_weight(g, 99, 0), 0);

    ⍝ graph_degree
    p = p + check("degree(0)=2", graph_degree(g, 0), 2);
    p = p + check("degree(1)=1", graph_degree(g, 1), 1);
    p = p + check("degree(4)=0", graph_degree(g, 4), 0);

    ⍝ graph_neighbors
    let nb = graph_neighbors(g, 0);
    p = p + check("neighbors(0) len=2", len(nb), 2);

    ⍝ graph_total_weight
    p = p + check("total_weight=58", graph_total_weight(g), 58);

    ⍝ graph_remove_edge
    g = graph_remove_edge(g, 0, 2);
    p = p + check("after remove edge_count=4", graph_edge_count(g), 4);
    p = p + check("has(0,2) after remove=0", graph_has_edge(g, 0, 2), 0);
    p = p + check("has(0,1) intact=1", graph_has_edge(g, 0, 1), 1);

    ⍝ a_edge_at (base index for edge 0 = 1)
    p = p + check("a_edge_at(g,0)=1", a_edge_at(g, 0), 1);

    print("graph tests passed:", p, "/ 20");
}
