⍝ list_test.ai — Tests for stdlib/list.ai
import { l_at, l_count, l_drop, l_fill, l_flatten2, l_max, l_min, l_range, l_reverse, l_sum, l_take } from "./list";

◯ check⟨label, got, expected⟩ {
    if (got == expected) {
        print("PASS:", label);
        return 1;
    }
    print("FAIL:", label, "got=", got, "expected=", expected);
    return 0;
}

◯ main⟨⟩ {
    let p = 0;

    let arr = [10, 20, 30, 40, 50];

    p = p + check("at(arr,0)=10", l_at(arr, 0), 10);
    p = p + check("at(arr,4)=50", l_at(arr, 4), 50);
    p = p + check("max([10..50])=50", l_max(arr), 50);
    p = p + check("min([10..50])=10", l_min(arr), 10);
    p = p + check("sum([10..50])=150", l_sum(arr), 150);

    let r = l_range(5);
    p = p + check("range(5) len=5", len(r), 5);
    p = p + check("range(5)[0]=0", l_at(r, 0), 0);
    p = p + check("range(5)[4]=4", l_at(r, 4), 4);

    let t = l_take(arr, 3);
    p = p + check("take(arr,3) len=3", len(t), 3);
    p = p + check("take(arr,3)[2]=30", l_at(t, 2), 30);

    let d = l_drop(arr, 2);
    p = p + check("drop(arr,2) len=3", len(d), 3);
    p = p + check("drop(arr,2)[0]=30", l_at(d, 0), 30);

    let rv = l_reverse(arr);
    p = p + check("reverse[0]=50", l_at(rv, 0), 50);
    p = p + check("reverse[4]=10", l_at(rv, 4), 10);

    let f = l_fill(4, 7);
    p = p + check("fill(4,7) len=4", len(f), 4);
    p = p + check("fill(4,7)[0]=7", l_at(f, 0), 7);

    let cnt = l_count([1, 2, 1, 3, 1], 1);
    p = p + check("count(1 in [1,2,1,3,1])=3", cnt, 3);

    let flat = l_flatten2([1, 2], [3, 4, 5]);
    p = p + check("flatten2 len=5", len(flat), 5);
    p = p + check("flatten2[2]=3", l_at(flat, 2), 3);

    print("list tests passed:", p, "/ 19");
}
