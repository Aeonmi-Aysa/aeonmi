⍝ math.ai — Standard math utilities (pure arithmetic, no imports)
⍝ Functions: 11 total

◯ m_abs⟨x⟩ {
    if (x < 0) { return 0 - x; }
    return x;
}

◯ m_clamp⟨x, lo, hi⟩ {
    if (x < lo) { return lo; }
    if (x > hi) { return hi; }
    return x;
}

◯ m_gcd⟨a, b⟩ {
    ⍝ Euclidean algorithm
    let aa = a;
    let bb = b;
    while (bb != 0) {
        let tmp = bb;
        ⍝ bb = aa - (aa/bb)*bb  (integer mod via subtraction loop)
        let q = aa / bb;
        let qi = 0;
        if (q >= 1) { qi = q - (q - 1); }
        ⍝ Use subtraction-based mod
        let rem = aa;
        while (rem >= bb) { rem = rem - bb; }
        aa = bb;
        bb = rem;
    }
    return aa;
}

◯ m_lcm⟨a, b⟩ {
    ⍝ LCM via GCD — m_gcd sorts before m_lcm (g < l) ✅
    let g = m_gcd(a, b);
    if (g == 0) { return 0; }
    return a * b / g;
}

◯ m_max⟨a, b⟩ {
    if (a > b) { return a; }
    return b;
}

◯ m_min⟨a, b⟩ {
    if (a < b) { return a; }
    return b;
}

◯ m_pow⟨base, exp⟩ {
    ⍝ Integer exponentiation (exp >= 0)
    let result = 1;
    let i = 0;
    while (i < exp) {
        result = result * base;
        i = i + 1;
    }
    return result;
}

◯ m_prod⟨arr⟩ {
    let result = 1;
    let i = 0;
    let n = len(arr);
    while (i < n) {
        result = result * arr.slice(i, i + 1).pop();
        i = i + 1;
    }
    return result;
}

◯ m_sign⟨x⟩ {
    if (x > 0) { return 1; }
    if (x < 0) { return -1; }
    return 0;
}

◯ m_sq⟨x⟩ {
    return x * x;
}

◯ m_sum⟨arr⟩ {
    let result = 0;
    let i = 0;
    let n = len(arr);
    while (i < n) {
        result = result + arr.slice(i, i + 1).pop();
        i = i + 1;
    }
    return result;
}

