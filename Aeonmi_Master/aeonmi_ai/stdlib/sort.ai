⍝ sort.ai — Selection sort and comparison utilities
⍝ Flat array: [v0, v1, v2, ...]
⍝ Functions: 11 total, no imports
⍝ a_ prefix helpers come before sort_ callers (alphabetical env capture)

◯ a_find_max⟨arr, from⟩ {
    ⍝ Index of maximum value in arr[from..len-1]
    let n = len(arr);
    let best_idx = from;
    let best_val = arr.slice(from, from + 1).pop();
    let i = from + 1;
    while (i < n) {
        let v = arr.slice(i, i + 1).pop();
        if (v > best_val) {
            best_val = v;
            best_idx = i;
        }
        i = i + 1;
    }
    return best_idx;
}

◯ a_find_min⟨arr, from⟩ {
    ⍝ Index of minimum value in arr[from..len-1]
    let n = len(arr);
    let best_idx = from;
    let best_val = arr.slice(from, from + 1).pop();
    let i = from + 1;
    while (i < n) {
        let v = arr.slice(i, i + 1).pop();
        if (v < best_val) {
            best_val = v;
            best_idx = i;
        }
        i = i + 1;
    }
    return best_idx;
}

◯ a_swap⟨arr, i, j⟩ {
    ⍝ Return new array with positions i and j swapped
    let n = len(arr);
    let vi = arr.slice(i, i + 1).pop();
    let vj = arr.slice(j, j + 1).pop();
    let result = [];
    let k = 0;
    while (k < n) {
        if (k == i) {
            result.push(vj);
        } else {
            if (k == j) {
                result.push(vi);
            } else {
                result.push(arr.slice(k, k + 1).pop());
            }
        }
        k = k + 1;
    }
    return result;
}

◯ sort_asc⟨arr⟩ {
    ⍝ Selection sort ascending
    let n = len(arr);
    let result = arr;
    let i = 0;
    while (i < n - 1) {
        let min_idx = a_find_min(result, i);
        result = a_swap(result, i, min_idx);
        i = i + 1;
    }
    return result;
}

◯ sort_desc⟨arr⟩ {
    ⍝ Selection sort descending
    let n = len(arr);
    let result = arr;
    let i = 0;
    while (i < n - 1) {
        let max_idx = a_find_max(result, i);
        result = a_swap(result, i, max_idx);
        i = i + 1;
    }
    return result;
}

◯ sort_is_asc⟨arr⟩ {
    ⍝ 1 if array is sorted ascending, 0 otherwise
    let n = len(arr);
    let ok = 1;
    let i = 0;
    while (i < n - 1) {
        let a = arr.slice(i, i + 1).pop();
        let b = arr.slice(i + 1, i + 2).pop();
        if (a > b) { ok = 0; }
        i = i + 1;
    }
    return ok;
}

◯ sort_is_desc⟨arr⟩ {
    ⍝ 1 if array is sorted descending, 0 otherwise
    let n = len(arr);
    let ok = 1;
    let i = 0;
    while (i < n - 1) {
        let a = arr.slice(i, i + 1).pop();
        let b = arr.slice(i + 1, i + 2).pop();
        if (a < b) { ok = 0; }
        i = i + 1;
    }
    return ok;
}

◯ sort_max2⟨a, b⟩ {
    if (a >= b) { return a; }
    return b;
}

◯ sort_med3⟨a, b, c⟩ {
    ⍝ Median of three values
    let hi = sort_max2(a, sort_max2(b, c));
    let ab_min = a + b - sort_max2(a, b);
    let lo = ab_min + c - sort_max2(ab_min, c);
    let total = a + b + c;
    return total - hi - lo;
}

◯ sort_min2⟨a, b⟩ {
    if (a <= b) { return a; }
    return b;
}

◯ sort_pair⟨a, b⟩ {
    ⍝ Returns [min, max]
    if (a <= b) { return [a, b]; }
    return [b, a];
}

◯ main⟨⟩ {
    let arr = [5, 2, 8, 1, 9, 3];
    let s = sort_asc(arr);
    print("sort module loaded — asc:", s.slice(0,1).pop(), s.slice(1,2).pop(), s.slice(2,3).pop());
}
