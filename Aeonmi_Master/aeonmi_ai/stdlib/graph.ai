⍝ graph.ai — Directed weighted graph using flat adjacency list
⍝ State: [n_nodes, from0, to0, weight0, from1, to1, weight1, ...]
⍝ Edge stride = 3 fields per edge
⍝ Functions: 11 total, no imports

◯ a_edge_at⟨g, i⟩ {
    ⍝ Base index in g for edge i (skip n_nodes header)
    return 1 + i * 3;
}

◯ graph_add_edge⟨g, from, to, weight⟩ {
    ⍝ Append edge (no dedup — caller responsibility)
    let result = [];
    let n = len(g);
    let i = 0;
    while (i < n) {
        result.push(g.slice(i, i + 1).pop());
        i = i + 1;
    }
    result.push(from);
    result.push(to);
    result.push(weight);
    return result;
}

◯ graph_degree⟨g, node⟩ {
    ⍝ Count edges where from == node (inline edge_count)
    let ec = (len(g) - 1) / 3;
    let count = 0;
    let i = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        let f = g.slice(base, base + 1).pop();
        if (f == node) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

◯ graph_edge_count⟨g⟩ {
    return (len(g) - 1) / 3;
}

◯ graph_has_edge⟨g, from, to⟩ {
    ⍝ 1 if directed edge from->to exists
    let ec = graph_edge_count(g);
    let i = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        let f = g.slice(base, base + 1).pop();
        let t = g.slice(base + 1, base + 2).pop();
        if (f == from && t == to) { return 1; }
        i = i + 1;
    }
    return 0;
}

◯ graph_neighbors⟨g, node⟩ {
    ⍝ Flat array of destination nodes reachable from node
    let ec = graph_edge_count(g);
    let result = [];
    let i = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        let f = g.slice(base, base + 1).pop();
        let t = g.slice(base + 1, base + 2).pop();
        if (f == node) { result.push(t); }
        i = i + 1;
    }
    return result;
}

◯ graph_new⟨n_nodes⟩ {
    return [n_nodes];
}

◯ graph_node_count⟨g⟩ {
    return g.slice(0, 1).pop();
}

◯ graph_remove_edge⟨g, from, to⟩ {
    ⍝ Remove first edge matching from->to
    let ec = graph_edge_count(g);
    let result = [graph_node_count(g)];
    let i = 0;
    let removed = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        let f = g.slice(base, base + 1).pop();
        let t = g.slice(base + 1, base + 2).pop();
        let w = g.slice(base + 2, base + 3).pop();
        if (f == from && t == to && removed == 0) {
            removed = 1;
        } else {
            result.push(f);
            result.push(t);
            result.push(w);
        }
        i = i + 1;
    }
    return result;
}

◯ graph_total_weight⟨g⟩ {
    ⍝ Sum of all edge weights
    let ec = graph_edge_count(g);
    let s = 0;
    let i = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        s = s + g.slice(base + 2, base + 3).pop();
        i = i + 1;
    }
    return s;
}

◯ graph_weight⟨g, from, to⟩ {
    ⍝ Weight of edge from->to (0 if absent)
    let ec = graph_edge_count(g);
    let i = 0;
    while (i < ec) {
        let base = a_edge_at(g, i);
        let f = g.slice(base, base + 1).pop();
        let t = g.slice(base + 1, base + 2).pop();
        if (f == from && t == to) {
            return g.slice(base + 2, base + 3).pop();
        }
        i = i + 1;
    }
    return 0;
}

◯ main⟨⟩ {
    let g = graph_new(4);
    g = graph_add_edge(g, 0, 1, 5);
    g = graph_add_edge(g, 0, 2, 3);
    g = graph_add_edge(g, 1, 3, 2);
    print("graph module loaded — nodes:", graph_node_count(g), "edges:", graph_edge_count(g), "total_weight:", graph_total_weight(g));
}
