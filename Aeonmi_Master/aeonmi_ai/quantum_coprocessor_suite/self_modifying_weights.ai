// self_modifying_weights.ai
// Evolves decision weights, writes qc_weights.json
// Run: aeonmi native self_modifying_weights.ai

function fn_round3(x) { return floor(x * 1000.0) / 1000.0; }

function fn_lcg_step(state) {
    let s = floor(state * 1664525 + 1013904223);
    s = s - floor(s / 4294967296) * 4294967296;
    return s;
}

function fn_rand01(state) {
    let s = fn_lcg_step(state);
    let v = s / 4294967296.0;
    return [s, v];
}

function fn_mutate(state, temp) {
    let r = fn_rand01(state);
    let s = r[0];
    let d = r[1] * 2 * temp - temp;
    return [s, d];
}

function fn_clamp(x, lo, hi) {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

function fn_predict(w0, w1, w2, w3, row) {
    let logit = w0*row[0] + w1*row[1] + w2*row[2] + w3*row[3];
    if logit > 0.5 { return 1; }
    return 0;
}

function fn_fitness(w0, w1, w2, w3, data) {
    let correct = 0;
    let i = 0;
    while i < len(data) {
        let row = data[i];
        if fn_predict(w0, w1, w2, w3, row) == row[4] { correct = correct + 1; }
        i = i + 1;
    }
    return correct / float(len(data));
}

function main() {
    print("=== SELF-MODIFYING WEIGHTS ===");
    let data = [
        [0.90, 0.80, 0.70, 0.10, 1],
        [0.20, 0.30, 0.20, 0.80, 0],
        [0.80, 0.90, 0.80, 0.10, 1],
        [0.10, 0.20, 0.10, 0.90, 0],
        [0.70, 0.70, 0.60, 0.20, 1],
        [0.30, 0.40, 0.30, 0.70, 0],
        [0.90, 0.60, 0.80, 0.20, 1],
        [0.40, 0.20, 0.40, 0.60, 0]
    ];

    let w0 = 0.50; let w1 = 0.30; let w2 = 0.70; let w3 = 0.20;
    let best = fn_fitness(w0, w1, w2, w3, data);
    print("Initial fitness: " + fn_round3(best));

    let rng = 42;
    let gen = 0;
    while gen < 80 {
        let temp = 0.60 / (1 + gen / 20);
        let m0 = fn_mutate(rng, temp); rng = m0[0]; let d0 = m0[1];
        let m1 = fn_mutate(rng, temp); rng = m1[0]; let d1 = m1[1];
        let m2 = fn_mutate(rng, temp); rng = m2[0]; let d2 = m2[1];
        let m3 = fn_mutate(rng, temp); rng = m3[0]; let d3 = m3[1];

        let gw0 = fn_clamp(w0 + d0*0.5, -2, 2);
        let gw1 = fn_clamp(w1 + d1*0.5, -2, 2);
        let gw2 = fn_clamp(w2 + d2*0.5, -2, 2);
        let gw3 = fn_clamp(w3 - abs(d3) - 0.05, -2, 2);
        let fit_g = fn_fitness(gw0, gw1, gw2, gw3, data);

        if fit_g > best {
            best = fit_g; w0 = gw0; w1 = gw1; w2 = gw2; w3 = gw3;
            print("gen=" + gen + " fit=" + fn_round3(best) + " w=[" + fn_round3(w0) + "," + fn_round3(w1) + "," + fn_round3(w2) + "," + fn_round3(w3) + "]");
        }
        gen = gen + 1;
    }

    print("Final fitness: " + fn_round3(best));
    let w_quantum = 0.75;
    let out = "{\"w_signal\":" + fn_round3(w0) + ",\"w_stability\":" + fn_round3(w1) + ",\"w_periodicity\":" + fn_round3(w2) + ",\"w_noise\":" + fn_round3(w3) + ",\"w_quantum\":" + fn_round3(w_quantum) + "}";
    write_file("qc_weights.json", out);
    print("Wrote qc_weights.json: " + out);
    return 0;
}

main();
