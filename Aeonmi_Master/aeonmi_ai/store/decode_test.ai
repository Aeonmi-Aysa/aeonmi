⍝ decode_test.ai — Tests for store/decode.ai
import { a_dec_buf_pos, dec_buf_count, dec_buf_data_at, dec_buf_data_len, dec_buf_extract, dec_buf_magic, dec_buf_type, dec_buf_version, dec_is_empty, dec_new, dec_total_data } from "./decode";

◯ check⟨label, got, expected⟩ {
    if (got == expected) {
        print("PASS:", label);
        return 1;
    }
    print("FAIL:", label, "got=", got, "expected=", expected);
    return 0;
}

◯ main⟨⟩ {
    let p = 0;

    ⍝ dec_new / dec_is_empty
    let s = dec_new();
    p = p + check("new empty=1", dec_is_empty(s), 1);
    p = p + check("new count=0", dec_buf_count(s), 0);

    ⍝ Build a stream from two manually-constructed encoded buffers
    ⍝ enc_make(ver, type, data) = [42, ver, type, data_len, checksum, ...data]
    ⍝ buf0 = enc_make(1, 0, [10,20,30]) -> checksum=60, len=3
    let buf0 = [42, 1, 0, 3, 60, 10, 20, 30];
    ⍝ buf1 = enc_make(2, 3, [100,200])  -> checksum=300, len=2
    let buf1 = [42, 2, 3, 2, 300, 100, 200];
    ⍝ stream = concat of buf0 ++ buf1
    let stream = [42, 1, 0, 3, 60, 10, 20, 30, 42, 2, 3, 2, 300, 100, 200];

    p = p + check("not empty", dec_is_empty(stream), 0);

    ⍝ dec_buf_count
    p = p + check("count=2", dec_buf_count(stream), 2);

    ⍝ dec_buf_magic
    p = p + check("magic(0)=42", dec_buf_magic(stream, 0), 42);
    p = p + check("magic(1)=42", dec_buf_magic(stream, 1), 42);

    ⍝ dec_buf_version
    p = p + check("version(0)=1", dec_buf_version(stream, 0), 1);
    p = p + check("version(1)=2", dec_buf_version(stream, 1), 2);

    ⍝ dec_buf_type
    p = p + check("type(0)=0", dec_buf_type(stream, 0), 0);
    p = p + check("type(1)=3", dec_buf_type(stream, 1), 3);

    ⍝ dec_buf_data_len
    p = p + check("data_len(0)=3", dec_buf_data_len(stream, 0), 3);
    p = p + check("data_len(1)=2", dec_buf_data_len(stream, 1), 2);

    ⍝ dec_buf_data_at
    p = p + check("data_at(0,0)=10", dec_buf_data_at(stream, 0, 0), 10);
    p = p + check("data_at(0,2)=30", dec_buf_data_at(stream, 0, 2), 30);
    p = p + check("data_at(1,0)=100", dec_buf_data_at(stream, 1, 0), 100);
    p = p + check("data_at(1,1)=200", dec_buf_data_at(stream, 1, 1), 200);

    ⍝ dec_total_data
    p = p + check("total_data=5", dec_total_data(stream), 5);

    ⍝ dec_buf_extract
    let extracted = dec_buf_extract(stream, 1);
    p = p + check("extract len=7", len(extracted), 7);
    p = p + check("extract[0]=42", extracted.slice(0, 1).pop(), 42);

    ⍝ a_dec_buf_pos
    p = p + check("pos(0)=0", a_dec_buf_pos(stream, 0), 0);
    p = p + check("pos(1)=8", a_dec_buf_pos(stream, 1), 8);

    print("decode tests passed:", p, "/ 20");
}
