// aeonmi:1
// hash:80bf0831310ed909
// tool:aeonmi unknown

import "./lexer" as dump_tokens;
import "./lexer" as keyword_kind;
import "./lexer" as tok;
import "./lexer" as tokenize;

fn main() {
  let t1 = tokenize("");
  assert_eq(len(t1), 1);
  assert_eq(__index_access(__index_access(t1, 0), "kind"), "EOF");
  log("PASS:T01 empty source");
  let t2 = tokenize("   
	  ");
  assert_eq(len(t2), 1);
  assert_eq(__index_access(__index_access(t2, 0), "kind"), "EOF");
  log("PASS:T02 whitespace only");
  let t3 = tokenize("+ - * / = < > ! % ^ & | ( ) { } [ ] , ; . :");
  assert_eq(__index_access(__index_access(t3, 0), "kind"), "Plus");
  assert_eq(__index_access(__index_access(t3, 1), "kind"), "Minus");
  assert_eq(__index_access(__index_access(t3, 2), "kind"), "Star");
  assert_eq(__index_access(__index_access(t3, 3), "kind"), "Slash");
  assert_eq(__index_access(__index_access(t3, 4), "kind"), "Equals");
  assert_eq(__index_access(__index_access(t3, 5), "kind"), "LessThan");
  assert_eq(__index_access(__index_access(t3, 6), "kind"), "GreaterThan");
  assert_eq(__index_access(__index_access(t3, 7), "kind"), "Bang");
  assert_eq(__index_access(__index_access(t3, 8), "kind"), "Percent");
  assert_eq(__index_access(__index_access(t3, 9), "kind"), "Caret");
  assert_eq(__index_access(__index_access(t3, 10), "kind"), "Ampersand");
  assert_eq(__index_access(__index_access(t3, 11), "kind"), "Pipe");
  assert_eq(__index_access(__index_access(t3, 12), "kind"), "OpenParen");
  assert_eq(__index_access(__index_access(t3, 13), "kind"), "CloseParen");
  assert_eq(__index_access(__index_access(t3, 14), "kind"), "OpenBrace");
  assert_eq(__index_access(__index_access(t3, 15), "kind"), "CloseBrace");
  assert_eq(__index_access(__index_access(t3, 16), "kind"), "OpenBracket");
  assert_eq(__index_access(__index_access(t3, 17), "kind"), "CloseBracket");
  assert_eq(__index_access(__index_access(t3, 18), "kind"), "Comma");
  assert_eq(__index_access(__index_access(t3, 19), "kind"), "Semicolon");
  assert_eq(__index_access(__index_access(t3, 20), "kind"), "Dot");
  assert_eq(__index_access(__index_access(t3, 21), "kind"), "Colon");
  log("PASS:T03 single-char operators");
  let t4 = tokenize("== != <= >= := :: && || -> =>");
  assert_eq(__index_access(__index_access(t4, 0), "kind"), "DoubleEquals");
  assert_eq(__index_access(__index_access(t4, 1), "kind"), "NotEquals");
  assert_eq(__index_access(__index_access(t4, 2), "kind"), "LessEqual");
  assert_eq(__index_access(__index_access(t4, 3), "kind"), "GreaterEqual");
  assert_eq(__index_access(__index_access(t4, 4), "kind"), "ColonEquals");
  assert_eq(__index_access(__index_access(t4, 5), "kind"), "ColonColon");
  assert_eq(__index_access(__index_access(t4, 6), "kind"), "AndAnd");
  assert_eq(__index_access(__index_access(t4, 7), "kind"), "OrOr");
  assert_eq(__index_access(__index_access(t4, 8), "kind"), "Arrow");
  assert_eq(__index_access(__index_access(t4, 9), "kind"), "FatArrow");
  log("PASS:T04 two-char operators");
  let t5 = tokenize("42 3.14 0 100");
  assert_eq(__index_access(__index_access(t5, 0), "kind"), "Number");
  assert_eq(__index_access(__index_access(t5, 0), "value"), "42");
  assert_eq(__index_access(__index_access(t5, 1), "kind"), "Number");
  assert_eq(__index_access(__index_access(t5, 1), "value"), "3.14");
  assert_eq(__index_access(__index_access(t5, 2), "value"), "0");
  assert_eq(__index_access(__index_access(t5, 3), "value"), "100");
  log("PASS:T05 number literals");
  let t6 = tokenize(""hello" "world"");
  assert_eq(__index_access(__index_access(t6, 0), "kind"), "String");
  assert_eq(__index_access(__index_access(t6, 0), "value"), "hello");
  assert_eq(__index_access(__index_access(t6, 1), "kind"), "String");
  assert_eq(__index_access(__index_access(t6, 1), "value"), "world");
  log("PASS:T06 string literals");
  let t7 = tokenize(""line1\nline2"");
  assert_eq(__index_access(__index_access(t7, 0), "kind"), "String");
  let escaped_val = __index_access(__index_access(t7, 0), "value");
  assert_eq(contains(escaped_val, "
"), true);
  log("PASS:T07 string escape newline");
  let t8 = tokenize("let const function return if else while for in null true false");
  assert_eq(__index_access(__index_access(t8, 0), "kind"), "Let");
  assert_eq(__index_access(__index_access(t8, 1), "kind"), "Const");
  assert_eq(__index_access(__index_access(t8, 2), "kind"), "Function");
  assert_eq(__index_access(__index_access(t8, 3), "kind"), "Return");
  assert_eq(__index_access(__index_access(t8, 4), "kind"), "If");
  assert_eq(__index_access(__index_access(t8, 5), "kind"), "Else");
  assert_eq(__index_access(__index_access(t8, 6), "kind"), "While");
  assert_eq(__index_access(__index_access(t8, 7), "kind"), "For");
  assert_eq(__index_access(__index_access(t8, 8), "kind"), "In");
  assert_eq(__index_access(__index_access(t8, 9), "kind"), "Null");
  assert_eq(__index_access(__index_access(t8, 10), "kind"), "True");
  assert_eq(__index_access(__index_access(t8, 11), "kind"), "False");
  log("PASS:T08 core keywords");
  let t9 = tokenize("quantum import export from match class struct enum impl async await pub");
  assert_eq(__index_access(__index_access(t9, 0), "kind"), "Quantum");
  assert_eq(__index_access(__index_access(t9, 1), "kind"), "Import");
  assert_eq(__index_access(__index_access(t9, 2), "kind"), "Export");
  assert_eq(__index_access(__index_access(t9, 3), "kind"), "From");
  assert_eq(__index_access(__index_access(t9, 4), "kind"), "Match");
  assert_eq(__index_access(__index_access(t9, 5), "kind"), "Class");
  assert_eq(__index_access(__index_access(t9, 6), "kind"), "Struct");
  assert_eq(__index_access(__index_access(t9, 7), "kind"), "Enum");
  assert_eq(__index_access(__index_access(t9, 8), "kind"), "Impl");
  assert_eq(__index_access(__index_access(t9, 9), "kind"), "Async");
  assert_eq(__index_access(__index_access(t9, 10), "kind"), "Await");
  assert_eq(__index_access(__index_access(t9, 11), "kind"), "Pub");
  log("PASS:T09 phase-1 keywords");
  let t10 = tokenize("foo bar baz _priv myVar count123");
  assert_eq(__index_access(__index_access(t10, 0), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t10, 0), "value"), "foo");
  assert_eq(__index_access(__index_access(t10, 4), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t10, 4), "value"), "myVar");
  assert_eq(__index_access(__index_access(t10, 5), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t10, 5), "value"), "count123");
  log("PASS:T10 identifiers");
  let t11 = tokenize("let x // this is a comment
= 5");
  assert_eq(__index_access(__index_access(t11, 0), "kind"), "Let");
  assert_eq(__index_access(__index_access(t11, 1), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t11, 2), "kind"), "Equals");
  assert_eq(__index_access(__index_access(t11, 3), "kind"), "Number");
  log("PASS:T11 line comments skipped");
  let t12 = tokenize("let
x = 5");
  let tok_x = __index_access(t12, 1);
  assert_eq(__index_access(tok_x, "kind"), "Ident");
  assert_eq(__index_access(tok_x, "line"), 2);
  log("PASS:T12 line tracking");
  let snippet = "function add(a, b) { return a + b; }";
  let t13 = tokenize(snippet);
  assert_eq(__index_access(__index_access(t13, 0), "kind"), "Function");
  assert_eq(__index_access(__index_access(t13, 1), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t13, 1), "value"), "add");
  assert_eq(__index_access(__index_access(t13, 2), "kind"), "OpenParen");
  assert_eq(__index_access(__index_access(t13, 3), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t13, 4), "kind"), "Comma");
  assert_eq(__index_access(__index_access(t13, 5), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t13, 6), "kind"), "CloseParen");
  assert_eq(__index_access(__index_access(t13, 7), "kind"), "OpenBrace");
  assert_eq(__index_access(__index_access(t13, 8), "kind"), "Return");
  assert_eq(__index_access(__index_access(t13, 9), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t13, 10), "kind"), "Plus");
  assert_eq(__index_access(__index_access(t13, 11), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t13, 12), "kind"), "Semicolon");
  assert_eq(__index_access(__index_access(t13, 13), "kind"), "CloseBrace");
  assert_eq(__index_access(__index_access(t13, 14), "kind"), "EOF");
  log("PASS:T13 function snippet");
  let t14 = tokenize("x.y 3.14");
  assert_eq(__index_access(__index_access(t14, 0), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t14, 1), "kind"), "Dot");
  assert_eq(__index_access(__index_access(t14, 2), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t14, 3), "kind"), "Number");
  assert_eq(__index_access(__index_access(t14, 3), "value"), "3.14");
  log("PASS:T14 dot disambiguation");
  let t15 = tokenize("abc");
  assert_eq(__index_access(__index_access(t15, 1), "kind"), "EOF");
  log("PASS:T15 EOF sentinel");
  let t16 = tokenize("let x = 42;");
  assert_eq(__index_access(__index_access(t16, 0), "kind"), "Let");
  assert_eq(__index_access(__index_access(t16, 1), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t16, 1), "value"), "x");
  assert_eq(__index_access(__index_access(t16, 2), "kind"), "Equals");
  assert_eq(__index_access(__index_access(t16, 3), "kind"), "Number");
  assert_eq(__index_access(__index_access(t16, 3), "value"), "42");
  assert_eq(__index_access(__index_access(t16, 4), "kind"), "Semicolon");
  assert_eq(__index_access(__index_access(t16, 5), "kind"), "EOF");
  log("PASS:T16 let statement");
  let t17 = tokenize("if (x == 5) { return true; } else { return false; }");
  assert_eq(__index_access(__index_access(t17, 0), "kind"), "If");
  assert_eq(__index_access(__index_access(t17, 2), "kind"), "Ident");
  assert_eq(__index_access(__index_access(t17, 3), "kind"), "DoubleEquals");
  assert_eq(__index_access(__index_access(t17, 4), "kind"), "Number");
  assert_eq(__index_access(__index_access(t17, 9), "kind"), "True");
  assert_eq(__index_access(__index_access(t17, 13), "kind"), "Else");
  assert_eq(__index_access(__index_access(t17, 17), "kind"), "False");
  log("PASS:T17 if/else");
  let t18 = tokenize("let a = 1; let b = 2; let c = a + b;");
  assert_eq(len(t18), 18);
  log("PASS:T18 token count");
  log("==============================");
  log("ALL LEXER TESTS PASSED");
}
