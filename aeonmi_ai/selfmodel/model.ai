⍝ model.ai — Phase 4: Self-Model
⍝ Mother tracks its own prediction accuracy, calibration, and drift.
⍝ Each cycle: Mother makes a prediction, observes outcome, scores itself.
⍝ Standalone. 10 fns + main = 11 total (budget ≤ 13).
⍝
⍝ Self-model state (flat memory):
⍝   predictions   — total predictions made
⍝   correct       — predictions that matched outcome
⍝   conf_sum      — sum of confidence scores on correct predictions
⍝   drift         — running |predicted - actual| error sum
⍝   last_pred     — last predicted verdict
⍝   last_outcome  — last actual verdict
⍝   accuracy      — correct / predictions  (0-100%)
⍝   calibration   — conf_sum / correct     (avg confidence when right)

◯ a_abs⟨n⟩ {
    if (n < 0) { return 0 - n; }
    return n;
}

◯ a_clamp⟨v, lo, hi⟩ {
    if (v < lo) { return lo; }
    if (v > hi) { return hi; }
    return v;
}

◯ b_m_recall⟨m, key⟩ {
    let total = len(m) / 3;
    let i = 0;
    while (i < total) {
        let base = i * 3;
        let k = m.slice(base, base + 1).pop();
        if (k == key) { return m.slice(base + 1, base + 2).pop(); }
        i = i + 1;
    }
    return 0;
}

◯ b_m_store⟨m, key, val⟩ {
    let total = len(m) / 3;
    let found = -1;
    let i = 0;
    while (i < total) {
        let base = i * 3;
        let k = m.slice(base, base + 1).pop();
        if (k == key) { found = i; }
        i = i + 1;
    }
    if (found == -1) {
        m.push(key);
        m.push(val);
        m.push(1);
        return m;
    }
    let result = [];
    let j = 0;
    while (j < total) {
        let b = j * 3;
        let ek = m.slice(b, b + 1).pop();
        let ev = m.slice(b + 1, b + 2).pop();
        let es = m.slice(b + 2, b + 3).pop();
        if (j == found) {
            result.push(ek);
            result.push(val);
            result.push(1);
        } else {
            result.push(ek);
            result.push(ev);
            result.push(es);
        }
        j = j + 1;
    }
    return result;
}

◯ c_accuracy⟨m⟩ {
    ⍝ correct / predictions * 100, clamped [0,100]
    let preds = b_m_recall(m, "predictions");
    let corr  = b_m_recall(m, "correct");
    if (preds == 0) { return 0; }
    return a_clamp(corr * 100 / preds, 0, 100);
}

◯ c_calibration⟨m⟩ {
    ⍝ avg confidence on correct calls; 0 if none correct
    let corr = b_m_recall(m, "correct");
    let csum = b_m_recall(m, "conf_sum");
    if (corr == 0) { return 0; }
    return a_clamp(csum / corr, 0, 100);
}

◯ c_observe⟨m, pred, outcome, conf⟩ {
    ⍝ record one prediction/outcome pair
    let preds = b_m_recall(m, "predictions");
    let corr  = b_m_recall(m, "correct");
    let csum  = b_m_recall(m, "conf_sum");
    let drift = b_m_recall(m, "drift");

    m = b_m_store(m, "predictions",  preds + 1);
    m = b_m_store(m, "last_pred",    pred);
    m = b_m_store(m, "last_outcome", outcome);

    let hit = 0; if (pred == outcome) { hit = 1; }
    if (hit == 1) {
        m = b_m_store(m, "correct",  corr + 1);
        m = b_m_store(m, "conf_sum", csum + conf);
    }
    let err = a_abs(pred - outcome);
    m = b_m_store(m, "drift", drift + err);
    return m;
}

◯ d_self_report⟨m⟩ {
    let preds = b_m_recall(m, "predictions");
    let corr  = b_m_recall(m, "correct");
    let drift = b_m_recall(m, "drift");
    let lp    = b_m_recall(m, "last_pred");
    let lo    = b_m_recall(m, "last_outcome");
    let acc   = c_accuracy(m);
    let cal   = c_calibration(m);
    print("=== MOTHER SELF-MODEL ===");
    print("Predictions  : " + preds);
    print("Correct      : " + corr);
    print("Accuracy     : " + acc + "%");
    print("Calibration  : " + cal + "  (avg conf when right)");
    print("Total drift  : " + drift + "  (prediction error sum)");
    print("Last pred    : " + lp + "  actual=" + lo);
    print("=== END SELF-MODEL ===");
}

◯ main⟨⟩ {
    ⍝ Simulate Mother predicting verdicts then observing real outcomes.
    ⍝ Format: c_observe(m, predicted, actual, confidence)
    ⍝ Verdicts: 0=ABORT 1=HOLD 2=PROCEED 3=ACCELERATE

    let m = [];

    ⍝ Round 1: predicted PROCEED, got PROCEED, conf=16 ✓
    m = c_observe(m, 2, 2, 16);

    ⍝ Round 2: predicted PROCEED, got PROCEED, conf=18 ✓
    m = c_observe(m, 2, 2, 18);

    ⍝ Round 3: predicted PROCEED, got HOLD (wrong), conf=8 ✗
    m = c_observe(m, 2, 1, 8);

    ⍝ Round 4: predicted ACCELERATE, got ACCELERATE, conf=20 ✓
    m = c_observe(m, 3, 3, 20);

    ⍝ Round 5: predicted PROCEED, got ABORT (wrong), conf=6 ✗
    m = c_observe(m, 2, 0, 6);

    ⍝ Round 6: predicted HOLD, got HOLD, conf=12 ✓
    m = c_observe(m, 1, 1, 12);

    d_self_report(m);
}
